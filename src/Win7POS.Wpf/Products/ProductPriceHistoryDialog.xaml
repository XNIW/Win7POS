<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Products.ProductPriceHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{loc:Loc priceHistory.title}"
        ShowHeader="False"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        Width="820"
        MinHeight="520"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: titolo -->
        <TextBlock Grid.Row="0" Text="{loc:Loc priceHistory.title}" Style="{StaticResource DialogTitleStyle}"/>
        <!-- Card: Barcode, Nome, Prezzi attuali -->
        <Border Grid.Row="1" Padding="12" Margin="0,0,0,12" Background="#FCFBFE" CornerRadius="10" BorderBrush="#E4DBEF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{loc:Loc products.barcode}" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding Barcode}" FontWeight="SemiBold" FontSize="14"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="16,0">
                    <TextBlock Text="{loc:Loc common.product}" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="{loc:Loc priceHistory.currentSalePrice}" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{Binding CurrentRetailPrice}" FontWeight="SemiBold" FontSize="14"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc priceHistory.currentPurchasePrice}" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{Binding CurrentPurchasePrice}" FontWeight="SemiBold" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Azioni: Aggiorna + Nuovo prezzo vendita/acquisto -->
        <Border Grid.Row="2" Padding="8" Margin="0,0,0,8" Background="#FCFBFE" CornerRadius="8" BorderBrush="#E4DBEF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" MinWidth="100" Height="32" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconSync}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.reload}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="{loc:Loc priceHistory.newSalePriceClp}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding NewRetailText, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditPrices}" Width="120" MinHeight="28" Style="{StaticResource ModernTextBoxStyle}"/>
                    <TextBlock Text="{loc:Loc priceHistory.newPurchasePrice}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <TextBox Text="{Binding NewPurchaseText, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditPrices}" Width="120" MinHeight="28" Style="{StaticResource ModernTextBoxStyle}"/>
                </StackPanel>
                <Button Grid.Column="2" MinWidth="120" Height="32" Command="{Binding ApplyNewPricesCommand}" Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc priceHistory.applyPrices}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Storico vendita -->
        <GroupBox Grid.Row="3" Header="{loc:Loc priceHistory.saleHistory}" Margin="0,0,0,8" Padding="8">
            <DataGrid ItemsSource="{Binding RetailHistory}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" MinHeight="120">
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="SelectableDataGridRowStyle"/>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <StaticResource ResourceKey="SelectableDataGridCellStyle"/>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc receipt.dateTime}" Binding="{Binding ChangedAt}" Width="160"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.type}" Binding="{Binding PriceType}" Width="70"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.previousPrice}" Binding="{Binding OldPrice}" Width="120"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.newPrice}" Binding="{Binding NewPrice}" Width="100"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.origin}" Binding="{Binding Source}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Storico acquisto -->
        <GroupBox Grid.Row="4" Header="{loc:Loc priceHistory.purchaseHistory}" Margin="0,0,0,8" Padding="8">
            <DataGrid ItemsSource="{Binding PurchaseHistory}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" MinHeight="120">
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="SelectableDataGridRowStyle"/>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <StaticResource ResourceKey="SelectableDataGridCellStyle"/>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc receipt.dateTime}" Binding="{Binding ChangedAt}" Width="160"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.type}" Binding="{Binding PriceType}" Width="70"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.previousPrice}" Binding="{Binding OldPrice}" Width="120"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.newPrice}" Binding="{Binding NewPrice}" Width="100"/>
                    <DataGridTextColumn Header="{loc:Loc priceHistory.origin}" Binding="{Binding Source}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <DockPanel Grid.Row="5" Margin="{StaticResource DialogFooterMargin}">
            <Button MinWidth="90" HorizontalAlignment="Left" IsCancel="True" Click="Close_Click" Style="{StaticResource DialogCancelButtonStyle}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="12,0" Foreground="Gray"/>
        </DockPanel>
    </Grid>
</chrome:DialogShellWindow>
