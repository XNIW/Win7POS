<Window x:Class="Win7POS.Wpf.Products.ExportDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Esporta dati"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLightBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Formato di esportazione" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RadioXlsx" Content="XLSX (un file)" IsChecked="True" Margin="0,0,16,0" Checked="Format_Changed"/>
            <RadioButton x:Name="RadioCsv" Content="CSV (cartella con più file)" Checked="Format_Changed"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="Destinazione" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0" Margin="0,0,8,0" MinHeight="32"
                     Style="{StaticResource ModernTextBoxStyle}"
                     IsReadOnly="True"/>
            <Button Grid.Column="1" Content="Sfoglia..." MinWidth="90" Height="32" Click="Browse_Click"/>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annulla" MinWidth="90" Height="36" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Esporta" MinWidth="90" Height="36" IsDefault="True" Click="Export_Click"/>
        </StackPanel>
    </Grid>
</Window>
