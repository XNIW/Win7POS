<UserControl x:Class="Win7POS.Wpf.Products.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100">
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}"/>
        <KeyBinding Key="M" Modifiers="Control" Command="{Binding EditCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding CopyNewCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </UserControl.InputBindings>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Margin="0,0,0,12"
                Background="{StaticResource BackgroundLightBrush}"
                Padding="12" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" MinWidth="110" MinHeight="36"
                        Content="Nuovo (Ctrl+N)"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NewCommand}"/>

                <Button Grid.Column="1" Margin="8,0,0,0" MinWidth="120" MinHeight="36"
                        Content="Modifica (Ctrl+M)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding EditCommand}"/>

                <Button Grid.Column="2" Margin="8,0,0,0" MinWidth="130" MinHeight="36"
                        Content="Duplica (Ctrl+R)"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding CopyNewCommand}"/>

                <Button Grid.Column="3" Margin="8,0,0,0" MinWidth="120" MinHeight="36"
                        Content="Elimina (Ctrl+D)"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding DeleteCommand}"/>

                <Button Grid.Column="4" Margin="8,0,0,0" MinWidth="130" MinHeight="36"
                        Content="Import dati"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding ImportCommand}"/>

                <!-- Search -->
                <TextBox Grid.Column="6" MinHeight="36"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="7" Margin="8,0,0,0" MinWidth="90" MinHeight="36"
                        Content="Cerca"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SearchCommand}"/>
            </Grid>
        </Border>

        <!-- Content: Categories (left) + Grid (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Categorie" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             DisplayMemberPath="Name"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          MouseDoubleClick="ProductsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Vendita" Binding="{Binding UnitPrice}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Acquisto" Binding="{Binding PurchasePrice}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding StockQty}" Width="70" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Fornitore" Binding="{Binding SupplierName}" Width="1*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="1*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Foreground="#6B5B73" Text="{Binding StatusMessage}"/>
        </DockPanel>
    </Grid>
</UserControl>
