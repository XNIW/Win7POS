<UserControl x:Class="Win7POS.Wpf.Products.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="RightAlignCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style x:Key="CenterAlignCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style x:Key="CatalogStatChipStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F4EFF8"/>
            <Setter Property="BorderBrush" Value="#DCCFE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="6,0,0,6"/>
        </Style>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewProductCommand}"/>
        <KeyBinding Key="M" Modifiers="Control" Command="{Binding EditProductCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding CopyNewCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeaderCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Loc shell.products}" Style="{StaticResource PageTitleTextStyle}"/>
                    <TextBlock Text="{Binding FilterSummary}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Margin="16,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ItemsControl ItemsSource="{Binding CatalogStatsChips}"
                                  HorizontalAlignment="Right">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Right"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CatalogStatChipStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="5,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding ResultSummary}"
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource FilterPanelStyle}" Margin="0,12,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                    <Button MinWidth="96" Height="36" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding NewProductCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc products.new}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="96" Height="36" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditProductCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconEdit}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc products.edit}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="108" Height="36" Style="{StaticResource OutlineButtonStyle}" Command="{Binding CopyNewCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconDuplicate}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc products.duplicate}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="96" Height="36" Style="{StaticResource OutlineButtonStyle}" Command="{Binding DeleteCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconDelete}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc common.delete}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="96" Height="36" Style="{StaticResource OutlineButtonStyle}" Command="{Binding ImportCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconImport}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc import.title}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="168" Height="36" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SupplierExcelImportCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconUploadFile}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc supplierExcelImport.title}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="96" Height="36" Style="{StaticResource OutlineButtonStyle}" Command="{Binding ExportDataCommand}" Margin="0,0,8,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconExport}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc export.title}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button MinWidth="120" Height="36" Style="{StaticResource OutlineButtonStyle}" Command="{Binding OpenPriceHistoryCommand}" Margin="0,0,0,8">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconHistory}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc priceHistory.title}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="{loc:Loc products.search}" Style="{StaticResource MutedTextStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox MinWidth="220"
                                 Height="36"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 ToolTip="{loc:Loc products.searchTooltip}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ApplyFiltersCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="{loc:Loc products.supplier}" Style="{StaticResource MutedTextStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox MinWidth="160"
                                  Height="36"
                                  VerticalContentAlignment="Center"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ItemsSource="{Binding FilteredSuppliers}"
                                  DisplayMemberPath="Name"
                                  TextSearch.TextPath="Name"
                                  Text="{Binding SupplierFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                  IsDropDownOpen="{Binding IsSupplierDropdownOpen, Mode=TwoWay}"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  ToolTip="{loc:Loc products.filterSupplierTooltip}">
                            <ComboBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ApplyFiltersCommand}"/>
                            </ComboBox.InputBindings>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="{loc:Loc products.category}" Style="{StaticResource MutedTextStyle}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox MinWidth="160"
                                  Height="36"
                                  VerticalContentAlignment="Center"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ItemsSource="{Binding FilteredCategories}"
                                  DisplayMemberPath="Name"
                                  TextSearch.TextPath="Name"
                                  Text="{Binding CategoryFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  IsDropDownOpen="{Binding IsCategoryDropdownOpen, Mode=TwoWay}"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  ToolTip="{loc:Loc products.selectToFilter}">
                            <ComboBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ApplyFiltersCommand}"/>
                            </ComboBox.InputBindings>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="3" MinWidth="118" Height="36" VerticalAlignment="Bottom" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ApplyFiltersCommand}" Margin="0,0,8,0">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconSearch}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc products.applyFilters}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" MinWidth="96" Height="36" VerticalAlignment="Bottom" Style="{StaticResource OutlineButtonStyle}" Command="{Binding ClearFiltersCommand}">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconFilterOff}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc common.clearFilters}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource FilterChipStyle}"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0">
                    <TextBlock Text="{Binding FilterSummary}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          MouseDoubleClick="ProductsGrid_MouseDoubleClick"
                          Style="{StaticResource ModernDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:Loc pos.cart.barcode}" Binding="{Binding Barcode}" Width="120" MinWidth="100"/>
                        <DataGridTextColumn Header="{loc:Loc products.name}" Binding="{Binding Name}" Width="2*" MinWidth="150"/>
                        <DataGridTextColumn Header="{loc:Loc products.articleCodeShort}" Binding="{Binding ArticleCode}" Width="105" MinWidth="90"/>
                        <DataGridTextColumn Header="{loc:Loc products.secondName}" Binding="{Binding Name2}" Width="1.2*" MinWidth="110"/>
                        <DataGridTextColumn Header="{loc:Loc products.sale}" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="86" MinWidth="72" ElementStyle="{StaticResource RightAlignCell}"/>
                        <DataGridTextColumn Header="{loc:Loc products.purchase}" Binding="{Binding PurchasePrice, StringFormat={}{0:N0}}" Width="92" MinWidth="76" ElementStyle="{StaticResource RightAlignCell}"/>
                        <DataGridTextColumn Header="{loc:Loc products.stock}" Binding="{Binding StockQty}" Width="64" MinWidth="52" ElementStyle="{StaticResource CenterAlignCell}"/>
                        <DataGridTextColumn Header="{loc:Loc products.supplierNoColon}" Binding="{Binding SupplierName}" Width="1*" MinWidth="100"/>
                        <DataGridTextColumn Header="{loc:Loc products.categoryNoColon}" Binding="{Binding CategoryName}" Width="1*" MinWidth="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#CCFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{loc:Loc common.loading}"
                               Style="{StaticResource PageTitleTextStyle}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <Border Background="#F8FFFFFF" Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding FilterSummary}"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="0,10,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="{Binding PagingStatus}"
                           Margin="0,0,20,0"
                           FontSize="12"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource OutlineButtonStyle}" Command="{Binding PrevPageCommand}" MinWidth="72" Height="34" Margin="0,0,8,0">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconPrev}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc common.previousShort}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource OutlineButtonStyle}" Command="{Binding NextPageCommand}" MinWidth="72" Height="34" Margin="0,0,12,0">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <TextBlock Text="{loc:Loc common.nextShort}" Margin="0,0,6,0"/>
                            <Path Data="{StaticResource IconNext}" Style="{StaticResource ButtonIconPathStyle}"/>
                        </StackPanel>
                    </Button>
                    <TextBox Text="{Binding GoPageText, UpdateSourceTrigger=PropertyChanged}"
                             Width="52"
                             Height="34"
                             Margin="0,0,6,0"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource ModernTextBoxStyle}"/>
                    <Button Style="{StaticResource OutlineButtonStyle}" Command="{Binding GoToPageCommand}" MinWidth="64" Height="34">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc common.go}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
