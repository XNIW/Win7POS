<UserControl x:Class="Win7POS.Wpf.Products.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="RightAlignCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style x:Key="CenterAlignCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewProductCommand}"/>
        <KeyBinding Key="M" Modifiers="Control" Command="{Binding EditProductCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding CopyNewCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </UserControl.InputBindings>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: struttura fissa a 2 righe (no wrapping) -->
        <Border Grid.Row="0" Margin="0,0,0,14"
                Background="{StaticResource BackgroundLightBrush}"
                Padding="16" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                ClipToBounds="False">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Riga 1: azioni -->
                <StackPanel x:Name="ToolbarActions" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button MinWidth="96" Height="36" Content="Nuovo" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding NewProductCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Modifica" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditProductCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Duplica" Style="{StaticResource OutlineButtonStyle}" Command="{Binding CopyNewCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Elimina" Style="{StaticResource OutlineButtonStyle}" Command="{Binding DeleteCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Import dati" Style="{StaticResource OutlineButtonStyle}" Command="{Binding ImportCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Esporta dati" Style="{StaticResource OutlineButtonStyle}" Command="{Binding ExportDataCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Storico prezzi" Style="{StaticResource OutlineButtonStyle}" Command="{Binding OpenPriceHistoryCommand}"/>
                </StackPanel>
                <!-- Riga 2: filtri fornitore + ricerca -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="Fornitore:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6B5B73" FontSize="12"/>
                    <ComboBox x:Name="SupplierComboBox"
                              MinWidth="160" MaxWidth="220" Height="36"
                              VerticalContentAlignment="Center"
                              Style="{StaticResource ModernComboBoxStyle}"
                              ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                              MaxDropDownHeight="280"
                              ToolTip="Filtra per fornitore"/>
                    <TextBlock Text="Cerca:" VerticalAlignment="Center" Margin="24,0,8,0" Foreground="#6B5B73" FontSize="12"/>
                    <TextBox MinWidth="180" MaxWidth="260" Height="36"
                             VerticalContentAlignment="Center"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Testo da cercare (Invio per cercare)">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button MinWidth="84" Margin="12,0,0,0" Height="36" Content="Cerca" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SearchCommand}"/>
                    <Button MinWidth="96" Margin="12,0,0,0" Height="36" Content="Azzera filtri" Style="{StaticResource OutlineButtonStyle}" Command="{Binding ClearFiltersCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content: Categorie (sinistra) + Griglia (destra) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pannello Categorie: più spazio tra voci -->
            <Border Grid.Column="0" Background="White" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Categorie" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Foreground="#666" FontSize="11" Margin="0,0,0,10">
                        <Run Text="Seleziona per filtrare"/>
                    </TextBlock>
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             DisplayMemberPath="Name"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0,2">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,0,0,2"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#A97BC7"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Riga filtri attivi + Griglia -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Riga filtri attivi -->
                <Border Grid.Row="0" Background="#F5F5F5" Padding="10,8" Margin="0,0,0,6" CornerRadius="4"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding FilterSummary, Mode=OneWay}" FontSize="11" Foreground="#555" TextWrapping="Wrap"/>
                </Border>

                <!-- DataGrid: compatto, zebra più visibile, selezione tema viola -->
                <Border Grid.Row="1" Background="White" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="0">
                    <DataGrid ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              RowBackground="White"
                              AlternatingRowBackground="#F3F0F5"
                              RowHeight="32"
                              MouseDoubleClick="ProductsGrid_MouseDoubleClick"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEE"
                              HeadersVisibility="Column"
                              BorderThickness="0">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E8D9F2"/>
                                        <Setter Property="Foreground" Value="#2F1F3A"/>
                                        <Setter Property="BorderBrush" Value="#8F63B8"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#F3ECF8"/>
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Padding" Value="8,8,8,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,0,8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#2F1F3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120" MinWidth="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*" MinWidth="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Cod. articolo" Binding="{Binding ArticleCode}" Width="100" MinWidth="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Secondo nome" Binding="{Binding Name2}" Width="1.2*" MinWidth="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Vendita" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="82" MinWidth="72" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Acquisto" Binding="{Binding PurchasePrice, StringFormat={}{0:N0}}" Width="82" MinWidth="72" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQty}" Width="56" MinWidth="48" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Fornitore" Binding="{Binding SupplierName}" Width="1*" MinWidth="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding CategoryName}" Width="1*" MinWidth="90" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer: paginazione unificata, pulsanti uniformi -->
        <Border Grid.Row="2" Margin="0,14,0,0" Padding="0,10,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Foreground="#6B5B73" VerticalAlignment="Center" Text="{Binding PagingStatus}" Margin="0,0,20,0" FontSize="12"/>
                <Button Content="Prec" Style="{StaticResource OutlineButtonStyle}" Command="{Binding PrevPageCommand}" MinWidth="64" Height="34" Margin="0,0,8,0"/>
                <Button Content="Succ" Style="{StaticResource OutlineButtonStyle}" Command="{Binding NextPageCommand}" MinWidth="64" Height="34" Margin="0,0,12,0"/>
                <TextBox Text="{Binding GoPageText, UpdateSourceTrigger=PropertyChanged}" Width="52" Height="34" Margin="0,0,6,0" VerticalContentAlignment="Center"
                         Style="{StaticResource ModernTextBoxStyle}"/>
                <Button Content="Vai" Style="{StaticResource OutlineButtonStyle}" Command="{Binding GoToPageCommand}" MinWidth="64" Height="34"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
