<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Products.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{Binding DialogTitle}"
        ShowHeader="False"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Width"
        MinWidth="560"
        MinHeight="480"
        ResizeMode="CanResize">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" Style="{StaticResource DialogTitleStyle}"/>
        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Barcode -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc products.barcode}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,0,0"
                             Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             IsReadOnly="{Binding IsBarcodeReadOnly}"/>

                    <!-- Nome -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.name}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,10,0,0"
                             Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"/>

                    <!-- Prezzo vendita -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.salePriceClp}"/>
                    <TextBox x:Name="PriceBox" Grid.Row="2" Grid.Column="1" Margin="8,10,0,0"
                             Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             KeyDown="PriceBox_KeyDown"
                             GotKeyboardFocus="PriceBox_GotKeyboardFocus"/>

                    <!-- Prezzo acquisto -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.purchasePrice}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="8,10,0,0"
                             Text="{Binding PurchasePriceText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"/>

                    <!-- Fornitore -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.supplier}"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" Margin="8,10,0,0" MinHeight="34"
                              ItemsSource="{Binding Suppliers}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              Text="{Binding SupplierText, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ModernComboBoxStyle}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedSupplier}"/>

                    <!-- Categoria -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.category}"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" Margin="8,10,0,0" MinHeight="34"
                              ItemsSource="{Binding Categories}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              Text="{Binding CategoryText, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ModernComboBoxStyle}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedCategory}"/>

                    <!-- Stock -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{Binding StockLabel, Mode=OneWay}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Margin="8,10,0,0" MinHeight="32"
                             VerticalAlignment="Center"
                             Text="{Binding StockText, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="False"
                             IsEnabled="True"
                             Style="{StaticResource ModernTextBoxStyle}"/>

                    <!-- Cod. articolo -->
                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.articleCode}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Margin="8,10,0,0"
                             Text="{Binding ArticleCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}" MinHeight="32"/>

                    <!-- Secondo nome -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="{loc:Loc products.secondName}"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Margin="8,10,0,0"
                             Text="{Binding Name2, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}" MinHeight="32"/>
                </Grid>
            </ScrollViewer>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button MinWidth="100" Margin="0,0,10,0" IsCancel="True"
                    Style="{StaticResource DialogCancelButtonStyle}" Command="{Binding CancelCommand}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.cancel}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button MinWidth="100" IsDefault="True"
                    Style="{StaticResource DialogActionButtonStyle}" Command="{Binding ConfirmCommand}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.save}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
