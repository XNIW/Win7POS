<Window x:Class="Win7POS.Wpf.Import.ApplyConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conferma Apply"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="380"
        MinHeight="160"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundLightBrush}">
    <Border Margin="16" Padding="20" Background="{StaticResource CardBgBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TitleText" Grid.Row="0" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
            <TextBlock x:Name="MessageText" Grid.Row="1" TextWrapping="Wrap" FontSize="13" Foreground="#333" Margin="0,0,0,20"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" MinWidth="100" Height="36" Margin="0,0,10,0" IsCancel="True"
                        Style="{StaticResource OutlineButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Conferma" MinWidth="100" Height="36" IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
