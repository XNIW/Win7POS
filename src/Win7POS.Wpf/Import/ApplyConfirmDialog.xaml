<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Import.ApplyConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Conferma"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        MinHeight="240"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="20" FontWeight="SemiBold" Foreground="#5E3F86" Margin="0,0,0,10"/>
        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="MessageText" Grid.Row="0" TextWrapping="Wrap" FontSize="14" Foreground="#444" LineHeight="22" Margin="0,0,0,28"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Annulla" MinWidth="120" Height="42" Margin="0,0,12,0" IsCancel="True"
                            Style="{StaticResource OutlineButtonStyle}" Click="Cancel_Click"/>
                    <Button Content="Conferma" MinWidth="120" Height="42" IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</chrome:DialogShellWindow>
