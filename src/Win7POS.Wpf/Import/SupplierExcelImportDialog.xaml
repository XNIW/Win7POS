<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Import.SupplierExcelImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Import Excel fornitore"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="1040"
        Height="720"
        MinWidth="820"
        MinHeight="560"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Import Excel fornitore" Style="{StaticResource DialogTitleStyle}"/>

        <Border Grid.Row="1" Margin="0,10,0,12" Padding="12" CornerRadius="8"
                Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="1. Scegli file" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="2. Analizza colonne" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="3. Correggi righe" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="4. Verifica Sync DB" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                <Border Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Scegli il file Excel del fornitore (.xls/.xlsx)." FontSize="15" FontWeight="SemiBold"/>
                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Scegli Excel fornitore"
                                    MinWidth="180"
                                    Height="42"
                                    Command="{Binding BrowseCommand}"
                                    Style="{StaticResource DialogActionButtonStyle}"/>
                            <TextBox Grid.Column="1"
                                     Margin="14,0,0,0"
                                     Height="42"
                                     IsReadOnly="True"
                                     Text="{Binding SelectedPath}"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Margin="0,18,0,0">
                            <TextBlock Foreground="#6B5B73"
                                       TextWrapping="Wrap"
                                       Text="Il flusso ProductDb/CSV esistente resta separato. Questo wizard usa le chiavi Android: barcode, productName, itemNumber, purchasePrice, retailPrice, quantity, supplier, category, secondProductName."/>
                            <TextBlock Margin="0,16,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding SelectedSheetName, StringFormat=Foglio rilevato: {0}}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding HeaderSummary}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding RowSummary}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding IssueSummary}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <WrapPanel>
                            <TextBlock Margin="0,0,16,0" Text="{Binding SelectedSheetName, StringFormat=Foglio: {0}}"/>
                            <TextBlock Margin="0,0,16,0" Text="{Binding NewProductsCount, StringFormat=Nuovi: {0}}"/>
                            <TextBlock Margin="0,0,16,0" Text="{Binding UpdatedProductsCount, StringFormat=Aggiornati: {0}}"/>
	                            <TextBlock Margin="0,0,16,0" Text="{Binding WarningsCount, StringFormat=Warning: {0}}"/>
	                            <TextBlock Text="{Binding ErrorsCount, StringFormat=Errori: {0}}"/>
	                        </WrapPanel>
	                        <WrapPanel Margin="0,8,0,0">
	                            <TextBlock Margin="0,0,16,0" Text="{Binding HeaderSummary}"/>
	                            <TextBlock Text="{Binding RowSummary}"/>
	                        </WrapPanel>
	                        <TextBlock Margin="0,8,0,0"
	                                   Foreground="#6B5B73"
	                                   TextWrapping="Wrap"
                                   Text="Richiesti: barcode, productName o itemNumber, purchasePrice. Disabilita colonne errate o correggi la chiave Android, poi premi Analizza per ricalcolare."/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Columns}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="enabled" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="originalColumnName" Binding="{Binding DisplayName}" IsReadOnly="True" Width="2*"/>
                        <DataGridTemplateColumn Header="canonicalKey" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ColumnKeyOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding CanonicalKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ColumnKeyOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding CanonicalKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="headerSource" Binding="{Binding HeaderSource}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="confidence" Binding="{Binding Confidence}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="sampleValues" Binding="{Binding SampleValues}" IsReadOnly="True" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="Warning" Margin="0,0,6,0">
                        <DataGrid ItemsSource="{Binding Warnings}" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </GroupBox>
                    <GroupBox Grid.Column="1" Header="Errori" Margin="6,0,0,0">
                        <DataGrid ItemsSource="{Binding Errors}" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasRetailPriceWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Attenzione: righe con purchasePrice ma retailPrice vuoto non sovrascrivono il prezzo vendita. Compila retailPrice per confermare il cambio."
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasBarcodeWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Righe senza barcode: digita il barcode nella colonna barcode oppure seleziona Skip per ignorare la riga."
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasIdentityWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Nuovi prodotti senza productName o itemNumber: compila una delle due colonne oppure seleziona Skip."
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasInvalidNumberWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Prezzi o quantita non validi: correggi purchasePrice, retailPrice o quantity prima di applicare."
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" Margin="0,0,0,10" Padding="10" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="8">
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="Calcola prezzo vendita da prezzo acquisto" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Markup %" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Width="70" Height="32" Text="{Binding MarkupPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,12,0"/>
                        <TextBlock Text="Arrotonda a" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="80" Height="32" ItemsSource="{Binding RoundToOptions}" SelectedItem="{Binding RoundTo, Mode=TwoWay}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,12,0"/>
                        <CheckBox Content="Solo retailPrice vuoti" IsChecked="{Binding ApplyOnlyEmptyRetailPrice, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Applica calcolo" MinWidth="120" Height="34" Command="{Binding ApplyMarkupCommand}" Style="{StaticResource DialogActionButtonStyle}"/>
                    </WrapPanel>
                </Border>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding EditableRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
	                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Skip" Binding="{Binding IsSkipped, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                        <DataGridTextColumn Header="barcode" Binding="{Binding Barcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <DataGridTextColumn Header="itemNumber" Binding="{Binding ItemNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="productName" Binding="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                        <DataGridTextColumn Header="secondProductName" Binding="{Binding SecondProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        <DataGridTextColumn Header="purchasePrice" Binding="{Binding PurchasePrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                        <DataGridTextColumn Header="retailPrice" Binding="{Binding RetailPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                        <DataGridTextColumn Header="quantity" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="supplier" Binding="{Binding Supplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                        <DataGridTextColumn Header="category" Binding="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Visibility="{Binding IsStep4, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding IsSyncPreviewStale, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Sync DB preview non aggiornato: torna allo Step 3 e premi Ricalcola Sync DB."
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0" Padding="12" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Verifica Sync Database" FontSize="15" FontWeight="SemiBold"/>
                            <WrapPanel Margin="0,10,0,0">
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncTotalRowsCount, StringFormat=Totale: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncNewProductsCount, StringFormat=Nuovi: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncUpdatedProductsCount, StringFormat=Aggiornamenti: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncNoChangeRowsCount, StringFormat=Senza modifiche: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncSkippedRowsCount, StringFormat=Skippati: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncWarningsCount, StringFormat=Warning: {0}}"/>
                                <TextBlock Text="{Binding SyncErrorsCount, StringFormat=Errori: {0}}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TabControl Grid.Row="1">
                    <TabItem Header="Nuovi">
                        <DataGrid ItemsSource="{Binding SyncNewProducts}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="row" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="barcode" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="itemNumber" Binding="{Binding ItemNumber}" Width="120"/>
                                <DataGridTextColumn Header="productName" Binding="{Binding ProductName}" Width="220"/>
                                <DataGridTextColumn Header="retailPrice" Binding="{Binding RetailPrice}" Width="110"/>
                                <DataGridTextColumn Header="purchasePrice" Binding="{Binding PurchasePrice}" Width="110"/>
                                <DataGridTextColumn Header="quantity" Binding="{Binding Quantity}" Width="90"/>
                                <DataGridTextColumn Header="supplier" Binding="{Binding Supplier}" Width="140"/>
                                <DataGridTextColumn Header="category" Binding="{Binding Category}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Aggiornamenti">
                        <DataGrid ItemsSource="{Binding SyncUpdatedProducts}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="row" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="barcode" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="before productName" Binding="{Binding Existing.ProductName}" Width="180"/>
                                <DataGridTextColumn Header="after productName" Binding="{Binding Updated.ProductName}" Width="180"/>
                                <DataGridTextColumn Header="before retailPrice" Binding="{Binding Existing.RetailPrice}" Width="120"/>
                                <DataGridTextColumn Header="after retailPrice" Binding="{Binding Updated.RetailPrice}" Width="120"/>
                                <DataGridTextColumn Header="diff" Binding="{Binding DiffSummary}" Width="4*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Senza modifiche">
                        <DataGrid ItemsSource="{Binding SyncNoChangeRows}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="row" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="barcode" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="productName" Binding="{Binding Updated.ProductName}" Width="220"/>
                                <DataGridTextColumn Header="retailPrice" Binding="{Binding Updated.RetailPrice}" Width="110"/>
                                <DataGridTextColumn Header="quantity" Binding="{Binding Updated.Quantity}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Skippati">
                        <DataGrid ItemsSource="{Binding SyncSkippedRows}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="original row" Binding="{Binding RowNumber}" Width="100"/>
                                <DataGridTextColumn Header="barcode" Binding="{Binding Barcode}" Width="160"/>
                                <DataGridTextColumn Header="itemNumber" Binding="{Binding ItemNumber}" Width="160"/>
                                <DataGridTextColumn Header="productName" Binding="{Binding ProductName}" Width="240"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Warning">
                        <DataGrid ItemsSource="{Binding SyncWarnings}" AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    </TabItem>
                    <TabItem Header="Errori">
                        <DataGrid ItemsSource="{Binding SyncErrors}" AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" Margin="{StaticResource DialogFooterMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#5E3F86"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Indietro" MinWidth="100" Height="42" Margin="0,0,8,0"
                        Command="{Binding BackCommand}" Style="{StaticResource DialogCancelButtonStyle}"/>
                <Button Content="Analizza" MinWidth="100" Height="42" Margin="0,0,8,0"
                        Command="{Binding AnalyzeCommand}" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogCancelButtonStyle}"/>
                <Button Content="Avanti" MinWidth="100" Height="42" Margin="0,0,8,0"
                        Command="{Binding NextCommand}" Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogActionButtonStyle}"/>
                <Button Content="Continua a Sync DB" MinWidth="150" Height="42" Margin="0,0,8,0"
                        Command="{Binding SyncPreviewCommand}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogActionButtonStyle}"/>
                <Button Content="Conferma e applica" MinWidth="150" Height="42" Margin="0,0,8,0"
                        Command="{Binding ApplyCommand}" Visibility="{Binding IsStep4, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogActionButtonStyle}"/>
                <Button Content="Annulla" MinWidth="100" Height="42" IsCancel="True"
                        Command="{Binding CancelCommand}" Style="{StaticResource DialogCancelButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</chrome:DialogShellWindow>
