<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Import.SupplierExcelImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{Binding Source={x:Static loc:PosLocalization.Current}, Path=[supplierExcelImport.title]}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="1040"
        Height="720"
        MaxWidth="1120"
        MaxHeight="720"
        MinWidth="820"
        MinHeight="560"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Loc supplierExcelImport.title}" Style="{StaticResource DialogTitleStyle}"/>

        <Border Grid.Row="1" Margin="0,10,0,12" Padding="12" CornerRadius="8"
                Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc supplierExcelImport.stepChooseFile}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{loc:Loc supplierExcelImport.stepAnalyzeColumns}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{loc:Loc supplierExcelImport.stepFixRows}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{loc:Loc supplierExcelImport.stepVerifySync}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
        <Grid>
            <Grid Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                <Border Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{loc:Loc supplierExcelImport.chooseFilePrompt}" FontSize="15" FontWeight="SemiBold"/>
                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button MinWidth="180"
                                    Height="42"
                                    Command="{Binding BrowseCommand}"
                                    Style="{StaticResource DialogActionButtonStyle}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <Path Data="{StaticResource IconSearch}" Style="{StaticResource ButtonIconPathStyle}"/>
                                    <TextBlock Text="{loc:Loc supplierExcelImport.chooseExcelButton}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                            <TextBox Grid.Column="1"
                                     Margin="14,0,0,0"
                                     Height="42"
                                     IsReadOnly="True"
                                     Text="{Binding SelectedPath}"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Margin="0,18,0,0">
                            <TextBlock Foreground="#6B5B73"
                                       TextWrapping="Wrap"
                                       Text="{loc:Loc supplierExcelImport.flowHelp}"/>
                            <TextBlock Margin="0,16,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding SelectedSheetName, StringFormat=Foglio rilevato: {0}}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding HeaderSummary}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding RowSummary}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E3F86"
                                       Text="{Binding IssueSummary}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <WrapPanel>
                            <TextBlock Margin="0,0,16,0" Text="{Binding SelectedSheetName, StringFormat=Foglio: {0}}"/>
                            <TextBlock Margin="0,0,16,0" Text="{Binding NewProductsCount, StringFormat=Nuovi: {0}}"/>
                            <TextBlock Margin="0,0,16,0" Text="{Binding UpdatedProductsCount, StringFormat=Aggiornati: {0}}"/>
	                            <TextBlock Margin="0,0,16,0" Text="{Binding WarningsCount, StringFormat=Warning: {0}}"/>
	                            <TextBlock Text="{Binding ErrorsCount, StringFormat=Errori: {0}}"/>
	                        </WrapPanel>
	                        <WrapPanel Margin="0,8,0,0">
	                            <TextBlock Margin="0,0,16,0" Text="{Binding HeaderSummary}"/>
	                            <TextBlock Text="{Binding RowSummary}"/>
	                        </WrapPanel>
	                        <TextBlock Margin="0,8,0,0"
	                                   Foreground="#6B5B73"
	                                   TextWrapping="Wrap"
                                   Text="{loc:Loc supplierExcelImport.requiredColumnsHelp}"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Columns}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="{loc:Loc supplierExcelImport.columnEnabled}" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.columnOriginalName}" Binding="{Binding DisplayName}" IsReadOnly="True" Width="2*"/>
                        <DataGridTemplateColumn Header="{loc:Loc supplierExcelImport.columnCanonicalKey}" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ColumnKeyOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding CanonicalKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ColumnKeyOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding CanonicalKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.columnHeaderSource}" Binding="{Binding HeaderSource}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.columnConfidence}" Binding="{Binding Confidence}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.columnSampleValues}" Binding="{Binding SampleValues}" IsReadOnly="True" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="{loc:Loc supplierExcelImport.warnings}" Margin="0,0,6,0">
                        <DataGrid ItemsSource="{Binding Warnings}" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </GroupBox>
                    <GroupBox Grid.Column="1" Header="{loc:Loc supplierExcelImport.errors}" Margin="6,0,0,0">
                        <DataGrid ItemsSource="{Binding Errors}" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasRetailPriceWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc supplierExcelImport.retailPriceWarning}"
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasBarcodeWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc supplierExcelImport.barcodeWarning}"
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasIdentityWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc supplierExcelImport.identityWarning}"
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding HasInvalidNumberWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc supplierExcelImport.invalidNumberWarning}"
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" Margin="0,0,0,10" Padding="10" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="8">
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc supplierExcelImport.markupTitle}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Loc supplierExcelImport.markupPercent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Width="70" Height="32" Text="{Binding MarkupPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Loc supplierExcelImport.roundTo}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="80" Height="32" ItemsSource="{Binding RoundToOptions}" SelectedItem="{Binding RoundTo, Mode=TwoWay}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,12,0"/>
                        <CheckBox Content="{loc:Loc supplierExcelImport.onlyEmptyRetailPrice}" IsChecked="{Binding ApplyOnlyEmptyRetailPrice, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button MinWidth="120" Height="34" Command="{Binding ApplyMarkupCommand}" Style="{StaticResource DialogActionButtonStyle}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc supplierExcelImport.applyMarkup}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Border>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding EditableRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
	                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="{loc:Loc supplierExcelImport.fieldSkip}" Binding="{Binding IsSkipped, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBarcode}" Binding="{Binding Barcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldItemNumber}" Binding="{Binding ItemNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldProductName}" Binding="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldSecondProductName}" Binding="{Binding SecondProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldPurchasePrice}" Binding="{Binding PurchasePrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldRetailPrice}" Binding="{Binding RetailPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldQuantity}" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldSupplier}" Binding="{Binding Supplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                        <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldCategory}" Binding="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Visibility="{Binding IsStep4, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Padding="10"
                            Background="#FFF8E1"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding IsSyncPreviewStale, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc supplierExcelImport.syncPreviewStale}"
                                   TextWrapping="Wrap"
                                   Foreground="#7A4A00"/>
                    </Border>
                    <Border Margin="0,6,0,0" Padding="12" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc supplierExcelImport.verifySyncDatabase}" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{loc:Loc supplierExcelImport.verifySyncHelp}"
                                       TextWrapping="Wrap"
                                       Foreground="#6B5B73"/>
                            <WrapPanel Margin="0,10,0,0">
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncTotalRowsCount, StringFormat=Totale: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncNewProductsCount, StringFormat=Nuovi: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncUpdatedProductsCount, StringFormat=Aggiornamenti: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncNoChangeRowsCount, StringFormat=Senza modifiche: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncSkippedRowsCount, StringFormat=Skippati: {0}}"/>
                                <TextBlock Margin="0,0,16,0" Text="{Binding SyncWarningsCount, StringFormat=Warning: {0}}"/>
                                <TextBlock Text="{Binding SyncErrorsCount, StringFormat=Errori: {0}}"/>
                            </WrapPanel>
                            <DockPanel Margin="0,10,0,0">
                                <TextBlock Text="{loc:Loc supplierExcelImport.search}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox MinWidth="260"
                                         Height="32"
                                         Text="{Binding SyncSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBoxStyle}"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TabControl Grid.Row="1">
                    <TabItem Header="{loc:Loc supplierExcelImport.tabNew}">
                        <DataGrid ItemsSource="{Binding SyncNewProductsView}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldRow}" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBarcode}" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldItemNumber}" Binding="{Binding ItemNumber}" Width="120"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldProductName}" Binding="{Binding ProductName}" Width="220"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldSecondProductName}" Binding="{Binding SecondProductName}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldRetailPrice}" Binding="{Binding RetailPrice}" Width="110"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldPurchasePrice}" Binding="{Binding PurchasePrice}" Width="110"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldQuantity}" Binding="{Binding Quantity}" Width="90"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldSupplier}" Binding="{Binding Supplier}" Width="140"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldCategory}" Binding="{Binding Category}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="{loc:Loc supplierExcelImport.tabUpdates}">
                        <DataGrid ItemsSource="{Binding SyncUpdatedProductsView}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldRow}" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBarcode}" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBeforeProductName}" Binding="{Binding Existing.ProductName}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldAfterProductName}" Binding="{Binding Updated.ProductName}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldAfterSecondProductName}" Binding="{Binding Updated.SecondProductName}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBeforeRetailPrice}" Binding="{Binding Existing.RetailPrice}" Width="120"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldAfterRetailPrice}" Binding="{Binding Updated.RetailPrice}" Width="120"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldDiff}" Binding="{Binding DiffSummary}" Width="4*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="{loc:Loc supplierExcelImport.tabNoChanges}">
                        <DataGrid ItemsSource="{Binding SyncNoChangeRowsView}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldRow}" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBarcode}" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldProductName}" Binding="{Binding Updated.ProductName}" Width="220"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldSecondProductName}" Binding="{Binding Updated.SecondProductName}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldRetailPrice}" Binding="{Binding Updated.RetailPrice}" Width="110"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldQuantity}" Binding="{Binding Updated.Quantity}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="{loc:Loc supplierExcelImport.tabSkipped}">
                        <DataGrid ItemsSource="{Binding SyncSkippedRowsView}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldOriginalRow}" Binding="{Binding RowNumber}" Width="100"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldBarcode}" Binding="{Binding Barcode}" Width="160"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldItemNumber}" Binding="{Binding ItemNumber}" Width="160"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldProductName}" Binding="{Binding ProductName}" Width="240"/>
                                <DataGridTextColumn Header="{loc:Loc supplierExcelImport.fieldSecondProductName}" Binding="{Binding SecondProductName}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="{loc:Loc supplierExcelImport.warnings}">
                        <DataGrid ItemsSource="{Binding SyncWarningsView}" AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    </TabItem>
                    <TabItem Header="{loc:Loc supplierExcelImport.errors}">
                        <DataGrid ItemsSource="{Binding SyncErrorsView}" AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="{StaticResource DialogFooterMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#5E3F86"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button MinWidth="100" Height="42" Margin="0,0,8,0"
                        Command="{Binding BackCommand}" Style="{StaticResource DialogCancelButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconPrev}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc supplierExcelImport.back}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="100" Height="42" Margin="0,0,8,0"
                        Command="{Binding AnalyzeCommand}" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogCancelButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconSearch}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc supplierExcelImport.analyze}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="100" Height="42" Margin="0,0,8,0"
                        Command="{Binding NextCommand}" Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogActionButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Text="{loc:Loc supplierExcelImport.next}" Margin="0,0,8,0"/>
                        <Path Data="{StaticResource IconNext}" Style="{StaticResource ButtonIconPathStyle}"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="150" Height="42" Margin="0,0,8,0"
                        Command="{Binding SyncPreviewCommand}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogActionButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconSync}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc supplierExcelImport.continueSyncDb}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="150" Height="42" Margin="0,0,8,0"
                        Command="{Binding ApplyCommand}" Visibility="{Binding IsStep4, Converter={StaticResource BoolToVis}}" Style="{StaticResource DialogActionButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconImport}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc supplierExcelImport.confirmApply}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="100" Height="42" IsCancel="True"
                        Command="{Binding CancelCommand}" Style="{StaticResource DialogCancelButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.cancel}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</chrome:DialogShellWindow>
