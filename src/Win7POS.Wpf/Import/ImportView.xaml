<UserControl x:Class="Win7POS.Wpf.Import.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             AllowDrop="True"
             Drop="OnRootDrop"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File picker (unified) -->
        <Border Grid.Row="0" Margin="0,0,0,12" Background="{StaticResource BackgroundLightBrush}" Padding="14" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="File:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}" MinHeight="36" Style="{StaticResource ModernTextBoxStyle}"/>
                <Button Grid.Column="2" Content="Browse..." Margin="12,0,0,0" MinWidth="100" Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding BrowseCommand}"/>
            </Grid>
        </Border>

        <!-- Options -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCsv}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="InsertNew" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ToggleButton Style="{StaticResource TinyToggleSwitchStyle}"
                              IsChecked="{Binding InsertNew, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCsv}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="UpdatePrice" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ToggleButton Style="{StaticResource TinyToggleSwitchStyle}"
                              IsChecked="{Binding UpdatePrice, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCsv}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="UpdateName" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ToggleButton Style="{StaticResource TinyToggleSwitchStyle}"
                              IsChecked="{Binding UpdateName, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                <TextBlock Text="DryRun" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ToggleButton Style="{StaticResource TinyToggleSwitchStyle}"
                              IsChecked="{Binding DryRun, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center" Foreground="DimGray"
                       Text="{Binding ApplyModeText}"/>
        </WrapPanel>

        <!-- Actions + progress -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Analizza" MinWidth="120" MinHeight="36" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding AnalyzeCommand}"/>
            <Button Grid.Column="1" Content="Apply" Margin="10,0,0,0" MinWidth="120" MinHeight="36" Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ApplyCommand}"/>
            <ProgressBar Grid.Column="3" Height="16" VerticalAlignment="Center"
                         IsIndeterminate="True">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding Status}" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Summary -->
        <Border Grid.Row="3" Margin="0,0,0,12" Background="White" Padding="14" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Summary" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Text="{Binding Summary}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         BorderThickness="0" Background="Transparent" Padding="0"/>
            </Grid>
        </Border>

        <!-- Preview -->
        <Border Grid.Row="4" Background="White" Padding="14" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="0,0,0,6" Foreground="Gray"
                           Text="{Binding DiffItems.Count, StringFormat=Items count: {0}}"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding DiffItems}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="All">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SelectionBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SelectionBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Hint -->
        <StackPanel Grid.Row="5" Margin="0,8,0,0">
            <TextBlock Foreground="Gray" Text="{Binding DbPath, StringFormat=DB: {0}}"/>
            <TextBlock Foreground="Gray"
                       Text="Seleziona .csv o .xlsx: l'app rileva automaticamente il tipo. Analizza/Apply usa la pipeline appropriata (CSV o Excel Database)."/>
        </StackPanel>
    </Grid>
</UserControl>
