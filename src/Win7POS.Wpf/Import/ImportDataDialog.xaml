<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Import.ImportDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:import="clr-namespace:Win7POS.Wpf.Import"
        Title="Import dati"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="860"
        Height="680"
        MinWidth="680"
        MinHeight="480"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Import dati" FontSize="18" FontWeight="SemiBold" Foreground="#5E3F86" Margin="0,0,0,6"/>
        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="0">
            <import:ImportView x:Name="ImportViewControl"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Annulla" MinWidth="110" Height="42" IsCancel="True" Style="{StaticResource OutlineButtonStyle}" Click="Annulla_Click"/>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
