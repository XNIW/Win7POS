<UserControl x:Class="Win7POS.Wpf.Pos.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             PreviewKeyDown="OnViewPreviewKeyDown"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="CartRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EBF2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280" MinWidth="240" MaxWidth="360"/>
        </Grid.ColumnDefinitions>

        <!-- Sinistra: carrello lista a righe -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource BackgroundLightBrush}" Padding="10,8" Margin="0,0,0,6" CornerRadius="8,8,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Loc pos.cart.productHeader}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{loc:Loc pos.cart.quantityHeader}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{loc:Loc pos.cart.priceHeader}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="{loc:Loc pos.cart.totalHeader}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="4" Width="36"/>
                </Grid>
            </Border>
            <ListBox x:Name="CartListBox" Grid.Row="1" ItemsSource="{Binding CartItems}" SelectedItem="{Binding SelectedCartItem, Mode=TwoWay}"
                     AlternationCount="2" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="CartListBox_SelectionChanged">
                <ListBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E9E1F2"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E9E1F2"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#222222"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#222222"/>
                </ListBox.Resources>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource CartRowStyle}">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="White"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="CartRow_PreviewMouseLeftButtonDown"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource Self}}" Value="1">
                                <Setter Property="Background" Value="#F7F7F7"/>
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E9E1F2"/>
                                <Setter Property="BorderBrush" Value="#8B6BA3"/>
                                <Setter Property="BorderThickness" Value="5,1,0,1"/>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    <Condition Binding="{Binding (Selector.IsSelectionActive), RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#E9E1F2"/>
                                <Setter Property="BorderBrush" Value="#8B6BA3"/>
                                <Setter Property="BorderThickness" Value="5,1,0,1"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <!-- Col 0: Nome + Barcode + Stock (sconto si vede in colonna Prezzo) -->
                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap" Foreground="#1F1F1F">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter Property="Foreground" Value="#222222"/>
                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Barcode}" FontSize="11" Foreground="Gray"/>
                                    <TextBlock Text="{Binding StockDisplay}" FontSize="11" Foreground="#8A6F9B">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StockQty}" Value="0">
                                                        <Setter Property="Foreground" Value="#C45C5C"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockQty}" Value="1">
                                                        <Setter Property="Foreground" Value="#B8860B"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockQty}" Value="2">
                                                        <Setter Property="Foreground" Value="#B8860B"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockQty}" Value="3">
                                                        <Setter Property="Foreground" Value="#B8860B"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" Padding="0" Focusable="False" IsTabStop="False"
                                        ToolTip="{loc:Loc pos.cart.editPrice}"
                                        Command="{Binding DataContext.OpenEditProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="36" MinHeight="36">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SmallRoundButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditable}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource IconEdit}" Style="{StaticResource ButtonIconPathStyle}" Width="14" Height="14"/>
                                </Button>
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button Content="-" FontSize="14" Padding="0" Focusable="False" IsTabStop="False"
                                        Command="{Binding DataContext.DecreaseQtyForLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SmallRoundButtonStyle}"/>
                                <Button Content="{Binding Quantity}"
                                        Command="{Binding DataContext.OpenChangeQuantityForLineCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        MinWidth="28" Height="28" Margin="6,0"
                                        Background="Transparent" BorderThickness="0"
                                        FontWeight="SemiBold" Cursor="Hand"
                                        Focusable="False" IsTabStop="False"
                                        ToolTip="{loc:Loc pos.cart.editQuantity}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="+" FontSize="14" Padding="0" Focusable="False" IsTabStop="False"
                                        Command="{Binding DataContext.IncreaseQtyForLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SmallRoundButtonStyle}"/>
                            </StackPanel>
                            <!-- Colonna Prezzo: prezzo scontato in bold; sotto (se HasDiscount) originale barrato + badge % -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                                <TextBlock Text="{Binding DiscountedUnitPriceDisplay}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,1,0,0"
                                            Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding OriginalUnitPriceDisplay}" Margin="0,0,6,0" FontSize="11"
                                               Foreground="#7A6F86" TextDecorations="Strikethrough" VerticalAlignment="Center"/>
                                    <Border Background="#E9D8F3" CornerRadius="4" Padding="6,1,6,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DiscountPercentDisplay, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" Foreground="#5D3E75"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <!-- Colonna Totale: totale netto in bold; sotto (se HasDiscount) totale originale barrato -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,18,0">
                                <TextBlock Text="{Binding DiscountedLineTotalDisplay}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding OriginalLineTotalDisplay}" HorizontalAlignment="Right" FontSize="11"
                                           Foreground="#7A6F86" TextDecorations="Strikethrough" Margin="0,1,0,0"
                                           Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="X" FontSize="12" Padding="0" Focusable="False" IsTabStop="False"
                                    Style="{StaticResource SmallRoundButtonStyle}"
                                    Foreground="White" Background="#C45C5C"
                                    Command="{Binding DataContext.RemoveLineForLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Destra: Inserimento / Scanner (solo BarcodeBox + Sconto + Add) -->
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14" Background="{StaticResource BackgroundLightBrush}" CornerRadius="8" Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="{loc:Loc pos.cart.scannerTitle}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                <TextBlock Text="{loc:Loc pos.cart.barcode}" FontSize="12" Foreground="#6B5B73" Margin="0,0,0,6"/>
                <TextBox x:Name="BarcodeBox"
                         MinHeight="40"
                         Margin="0,0,0,6"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="BarcodeBox_KeyDown"/>
                <TextBlock Text="{Binding PendingInputQuantityDisplay}"
                           Margin="0,0,0,8"
                           FontSize="11"
                           Foreground="#7B4FA3"
                           FontWeight="SemiBold"/>
                <Button MinWidth="120" MinHeight="38" Margin="0,0,0,10" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddBarcodeCommand}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.add}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120" MinHeight="38" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenDiscountCommand}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconDiscount}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.discount}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120" MinHeight="38" Margin="0,0,0,10" Style="{StaticResource OutlineButtonStyle}" Command="{Binding OpenChangeQuantityCommand}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconQuantity}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.changeQuantity}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120" MinHeight="38" Margin="0,0,0,10" Style="{StaticResource OutlineButtonStyle}" Command="{Binding PrintLastReceiptCommand}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconPrint}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.printLast}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120" MinHeight="38" Margin="0,0,0,10" Style="{StaticResource OutlineButtonStyle}" Command="{Binding OpenCashDrawerCommand}" ToolTip="{loc:Loc shell.openCashDrawerTooltip}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconCashDrawer}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc shell.openCashDrawer}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="120" MinHeight="38" Style="{StaticResource OutlineButtonStyle}" Command="{Binding OpenResoScanCommand}"
                        ToolTip="{loc:Loc pos.cart.refundTooltip}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconReturn}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.refundScanReceipt}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Basso: Sospendi + Recupera + Svuota + Articoli: N + Totale grande + Paga -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0" Background="{StaticResource PrimaryBrush}" Padding="16,14" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding SuspendCartCommand}"
                        Style="{StaticResource FooterSecondaryButtonStyle}"
                        MinWidth="90" Height="42" Margin="0,0,0,0">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconSuspend}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.suspend}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Command="{Binding RecoverCartCommand}"
                        Style="{StaticResource FooterSecondaryButtonStyle}"
                        MinWidth="90" Height="42" Margin="10,0,0,0">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconRecover}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.recover}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Command="{Binding ClearCartCommand}"
                        Style="{StaticResource FooterSecondaryButtonStyle}"
                        MinWidth="90" Height="42" Margin="10,0,0,0">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc pos.cart.clear}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Foreground="White" FontSize="14" Text="{loc:Loc pos.cart.itemsCountPrefix}"/>
                    <TextBlock Foreground="White" FontSize="14" Margin="4,0,0,0" Text="{Binding ItemsCount}"/>
                </StackPanel>
                <Grid Grid.Row="1" Grid.Column="4"
                      Width="280"
                      Margin="0,10,18,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="18"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{loc:Loc pos.cart.totalSpend}"
                               Foreground="#E8E0F0"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,0,1"/>

                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="{Binding FinalTotalDisplay}"
                               Foreground="#FF9A8B"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF9A8B"/>
                                <Setter Property="FontSize" Value="30"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                        <Setter Property="FontSize" Value="28"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Grid.Row="1" Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding OriginalTotalDisplay}"
                                   Foreground="#C8B8D0"
                                   FontSize="12"
                                   TextDecorations="Strikethrough"/>
                        <TextBlock Text="{loc:Loc pos.cart.discountLabel}"
                                   Foreground="#C8B8D0"
                                   FontSize="12"
                                   Margin="6,0,4,0"/>
                        <TextBlock Text="{Binding DiscountAmountDisplay}"
                                   Foreground="#C8B8D0"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
                <Button Grid.Row="1" Grid.Column="5" Grid.ColumnSpan="2" MinWidth="180" Height="48" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold"
                        Command="{Binding PayCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="{StaticResource PrimaryLighterBrush}" Foreground="White">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconPay}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.pay}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Panel.ZIndex="8"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                MaxWidth="560"
                Margin="16,0,320,14"
                Padding="12,10"
                Background="{Binding StatusToastBackground}"
                BorderBrush="{Binding StatusToastBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsStatusToastVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="{Binding StatusToastBorderBrush}" Margin="0,0,8,0">
                    <TextBlock Text="{Binding StatusToastIconText}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding StatusToastSeverityText}" Foreground="{Binding StatusToastForeground}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusToastMessage}"
                           Foreground="{Binding StatusToastForeground}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding StatusToastMessage}"/>
                <Button Grid.Column="3" Width="30" Height="30" Margin="10,0,0,0"
                        Content="×"
                        Command="{Binding DismissStatusToastCommand}"
                        Visibility="{Binding CanDismissStatusToast, Converter={StaticResource BoolToVis}}"
                        AutomationProperties.Name="{loc:Loc notice.dismiss}"
                        ToolTip="{loc:Loc notice.dismiss}"/>
            </Grid>
        </Border>

        <!-- Overlay IsBusy: pagamento, stampa, operazioni lunghe -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#E0FFFFFF" Panel.ZIndex="10"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="6" Margin="0,0,0,12"/>
                <TextBlock Text="{loc:Loc common.loading}" FontSize="14" Foreground="#555"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
