<UserControl x:Class="Win7POS.Wpf.Pos.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded" KeyDown="OnKeyDown" PreviewKeyDown="OnPaymentPreviewKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Col 0: Scontrino + Stampa PDF, compatti -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,6,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Stampa scontrino" FontSize="17" FontWeight="SemiBold" Foreground="#2E2236" VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1" Style="{StaticResource TinyToggleSwitchStyle}"
                                  IsChecked="{Binding ShouldPrint, Mode=TwoWay}"
                                  Margin="10,0,0,0" VerticalAlignment="Center"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="{Binding ReceiptPreviewFirstLine, Mode=OneWay}"
                                   FontFamily="Courier New" FontSize="11" FontWeight="Bold"
                                   TextWrapping="NoWrap" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ReceiptPreviewRest, Mode=OneWay}"
                                   FontFamily="Courier New" FontSize="10"
                                   TextWrapping="NoWrap" VerticalAlignment="Top"/>
                    </StackPanel>
                </ScrollViewer>
                <!-- PDF: Boleta + switch stampa automatica -->
                <GroupBox Grid.Row="2" Header="PDF" Margin="0,6,0,0" Padding="6"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Button x:Name="BoletaNumberButton"
                                MinWidth="80" MinHeight="28" Padding="6,2" Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Content="{Binding NextBoletaNumberText}"
                                FontWeight="SemiBold" FontSize="11"
                                Cursor="Hand" Click="BoletaNumberButton_Click" Focusable="False"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stampa automatica" FontSize="17" FontWeight="SemiBold" Foreground="#2E2236" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource TinyToggleSwitchStyle}"
                                          IsChecked="{Binding AutoPrintPdfSii, Mode=TwoWay}"
                                          Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>

        <!-- Col 1: Fiscale (SII Web) - più spazio, area pulita -->
        <Border Grid.Row="0" Grid.Column="1"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Margin="0,0,6,0"
                Padding="14"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Fiscale (SII Web)" FontWeight="SemiBold" FontSize="12" Foreground="#555" Margin="0,0,0,10"/>
                <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="6" BorderBrush="#E5E5E5" BorderThickness="1" Padding="12">
                    <TextBlock Text="Area fiscale temporaneamente disattivata"
                               Foreground="#888" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Col 2: Rapidi (tagli contanti + importo) più compatti -->
        <Border Grid.Row="0" Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,6,0" Padding="10">
            <StackPanel>
                <TextBlock Text="Rapidi" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                <TextBlock Text="Somma (CLP)" FontSize="10" Foreground="Gray" Margin="0,0,0,4"/>
                <Button Content="+ 20000" Margin="0,0,0,6" Style="{StaticResource SecondaryButtonStyle}" MinHeight="40" FontSize="15" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="20000"/>
                <Button Content="+ 10000" Margin="0,0,0,6" Style="{StaticResource SecondaryButtonStyle}" MinHeight="40" FontSize="15" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="10000"/>
                <Button Content="+ 5000" Margin="0,0,0,6" Style="{StaticResource SecondaryButtonStyle}" MinHeight="40" FontSize="15" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="5000"/>
                <Button Content="+ 2000" Margin="0,0,0,6" Style="{StaticResource SecondaryButtonStyle}" MinHeight="40" FontSize="15" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="2000"/>
                <Button Content="+ 1000" Margin="0,0,0,6" Style="{StaticResource SecondaryButtonStyle}" MinHeight="40" FontSize="15" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="1000"/>
                <TextBlock Text="Importo" FontSize="10" Foreground="Gray" Margin="0,10,0,4"/>
                <Button Content="Arrotonda" Margin="0,0,0,6" Style="{StaticResource OutlineButtonStyle}" MinHeight="38" FontSize="14" Focusable="False"
                        Command="{Binding SetRoundedTotalCommand}"/>
                <Button Content="Importo esatto" Margin="0,0,0,6" Style="{StaticResource OutlineButtonStyle}" MinHeight="38" FontSize="14" Focusable="False"
                        Command="{Binding SetExactTotalCommand}"/>
                <Button Content="Tutto su carta (+)" Margin="0,0,0,6" Style="{StaticResource OutlineButtonStyle}" MinHeight="38" FontSize="14" Focusable="False"
                        Command="{Binding PayAllCardCommand}"/>
            </StackPanel>
        </Border>

        <!-- Col 3: Pagamento (focus principale) - Totale da pagare meno invasivo, Manca/Resto evidente -->
        <Border Grid.Row="0" Grid.Column="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Totale da pagare" FontSize="12" Foreground="#555" Margin="0,0,0,2"/>
                <TextBlock Grid.Row="1" FontWeight="Bold" FontSize="20" Margin="0,0,0,10">
                    <Run Text="{Binding TotalDueText, Mode=OneWay}"/><Run Text=" CLP"/>
                </TextBlock>
                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Contanti:" VerticalAlignment="Center" Width="72" FontSize="13" FontWeight="SemiBold"/>
                    <TextBox x:Name="CashBox" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" FontSize="18" MinHeight="44"
                             Text="{Binding CashReceived, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="CashBox_GotFocus" LostFocus="CashBox_LostFocus"/>
                </Grid>
                <Grid Grid.Row="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Carta:" VerticalAlignment="Center" Width="72" FontSize="12" Foreground="#666"/>
                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" FontSize="14" MinHeight="36"
                             Text="{Binding CardAmount, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="CardBox_GotFocus" LostFocus="CardBox_LostFocus"/>
                </Grid>
                <TextBlock Grid.Row="4" Margin="0,0,0,4" FontSize="11" Foreground="Gray">
                    <Run Text="Pagato "/><Run Text="{Binding TotalPaidText, Mode=OneWay}"/>
                </TextBlock>
                <Border Grid.Row="5" Margin="0,0,0,12" Padding="12,10" Background="#E8F5E9" CornerRadius="8" BorderBrush="#4CAF50" BorderThickness="1">
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#2E7D32"
                               Text="{Binding RestoOrMissingDisplay, Mode=OneWay}"/>
                </Border>
                <!-- Tastierino numerico -->
                <Viewbox Grid.Row="6" Stretch="Uniform" StretchDirection="DownOnly" MaxWidth="560" Margin="0,8,0,0">
                    <UniformGrid Rows="4" Columns="3" Width="500" Height="380">
                        <Button Content="7" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="7"/>
                        <Button Content="8" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="8"/>
                        <Button Content="9" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="9"/>
                        <Button Content="4" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="4"/>
                        <Button Content="5" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="5"/>
                        <Button Content="6" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="6"/>
                        <Button Content="1" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="1"/>
                        <Button Content="2" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="2"/>
                        <Button Content="3" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="3"/>
                        <Button Content="0" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="0"/>
                        <Button Content="00" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="00"/>
                        <Button Content="⌫" Margin="5" Padding="14" MinHeight="72" FontSize="22" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Command="{Binding BackspaceCommand}"/>
                    </UniformGrid>
                </Viewbox>
            </Grid>
        </Border>

        <!-- Bottom: Sospendi + Annulla + Conferma pagamento -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Sospendi" MinWidth="110" Height="40" Margin="0,0,10,0"
                    Style="{StaticResource AccentButtonStyle}" Command="{Binding SuspendCommand}"/>
            <Button Content="Annulla" MinWidth="120" Height="40" Margin="0,0,10,0" Style="{StaticResource OutlineButtonStyle}" Command="{Binding CancelCommand}"/>
            <Button Content="Conferma pagamento" MinWidth="220" Height="48" FontSize="15" FontWeight="SemiBold"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ConfirmCommand}"
                    IsEnabled="{Binding IsValid}"/>
        </StackPanel>
    </Grid>
</UserControl>
