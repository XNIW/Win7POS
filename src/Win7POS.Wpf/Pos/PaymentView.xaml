<UserControl x:Class="Win7POS.Wpf.Pos.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded" KeyDown="OnKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Col 0: Scontrino (receipt preview, 80mm style) + Stampa PDF sotto -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,6,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Scontrino" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" Content="Stampa" IsChecked="{Binding ShouldPrint}" VerticalAlignment="Center"/>
                </Grid>
                <TextBox Grid.Row="1" Text="{Binding ReceiptPreviewText, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11" VerticalContentAlignment="Top"/>
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,10,0,0"
                        Padding="10"
                        Background="{StaticResource BackgroundLightBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Stampa PDF" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Boleta N°:" FontSize="11" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Button Content="-" MinWidth="32" MinHeight="28"
                                    Style="{StaticResource SmallRoundButtonStyle}"
                                    Command="{Binding DecrementBoletaCommand}" VerticalAlignment="Center" Focusable="False"/>
                            <TextBox Text="{Binding NextBoletaNumberText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="70" Margin="4,0" Padding="4,2"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     FontWeight="SemiBold" FontSize="12"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                            <Button Content="+" MinWidth="32" MinHeight="28"
                                    Style="{StaticResource SmallRoundButtonStyle}"
                                    Command="{Binding IncrementBoletaCommand}" VerticalAlignment="Center" Focusable="False"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="{Binding FiscalHeaderText, Mode=OneWay}" FontFamily="Courier New" FontSize="9" TextWrapping="NoWrap" Margin="0,0,0,2"/>
                                <Image x:Name="SiiQrImage"
                                       Margin="0,12,0,6"
                                       Width="220" Height="70"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FiscalFooterText, Mode=OneWay}" FontFamily="Courier New" FontSize="9" TextWrapping="NoWrap"/>
                            </StackPanel>
                        </ScrollViewer>
                        <TextBlock Grid.Row="2" Text="{Binding FiscalStatus, Mode=OneWay}" Foreground="Gray" FontSize="10" Margin="0,0,0,6"/>
                        <Button Grid.Row="3" Content="Stampa PDF" MinWidth="120" MinHeight="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding PrintPdfCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Col 1: Fiscale (SII Web) -->
        <Border Grid.Row="0" Grid.Column="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Margin="0,0,6,0"
                Padding="12"
                Background="{StaticResource BackgroundLightBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Fiscale (SII Web)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <WebBrowser x:Name="SiiWeb" Grid.Row="1"/>
                <TextBlock Grid.Row="2" Text="Cookie salvati: al prossimo pagamento non dovrebbe richiedere login."
                           Foreground="Gray" FontSize="10" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Col 2: Rapidi (quick buttons) -->
        <Border Grid.Row="0" Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,6,0" Padding="12">
            <StackPanel>
                <TextBlock Text="Rapidi" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Somma (CLP)" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                <Button Content="+ 20000" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="20000"/>
                <Button Content="+ 10000" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="10000"/>
                <Button Content="+ 5000" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="5000"/>
                <Button Content="+ 2000" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="2000"/>
                <Button Content="+ 1000" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding AddQuickAmountCommand}" CommandParameter="1000"/>
                <TextBlock Text="Importo" FontSize="11" Foreground="Gray" Margin="0,14,0,6"/>
                <Button Content="≈ Totale arrot." Margin="0,0,0,10" Style="{StaticResource OutlineButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding SetRoundedTotalCommand}"/>
                <Button Content="= Totale esatto" Margin="0,0,0,10" Style="{StaticResource OutlineButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding SetExactTotalCommand}"/>
                <Button Content="Carta (tutto)" Margin="0,0,0,10" Style="{StaticResource OutlineButtonStyle}" MinHeight="46" FontSize="16" Focusable="False"
                        Command="{Binding PayAllCardCommand}"/>
            </StackPanel>
        </Border>

        <!-- Col 3: Total pesos + Contanti/Carta + Resto in evidenza + Tastierino grande -->
        <Border Grid.Row="0" Grid.Column="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="18" Margin="0,0,0,8">
                    <Run Text="Total pesos "/><Run Text="{Binding TotalDueText, Mode=OneWay}"/>
                </TextBlock>
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Contanti:" VerticalAlignment="Center" Width="70" FontSize="14"/>
                    <TextBox x:Name="CashBox" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" FontSize="16"
                             Text="{Binding CashReceived, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="CashBox_GotFocus" LostFocus="CashBox_LostFocus"/>
                </Grid>
                <Grid Grid.Row="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Carta:" VerticalAlignment="Center" Width="70" FontSize="14"/>
                    <TextBox Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" FontSize="16"
                             Text="{Binding CardAmount, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="CardBox_GotFocus" LostFocus="CardBox_LostFocus"/>
                </Grid>
                <TextBlock Grid.Row="3" Margin="0,0,0,6" FontSize="15" Foreground="Gray">
                    <Run Text="Pagato "/><Run Text="{Binding TotalPaidText, Mode=OneWay}"/>
                </TextBlock>
                <Border Grid.Row="4" Margin="0,0,0,12" Padding="14,12" Background="#E8F5E9" CornerRadius="6" BorderBrush="#4CAF50" BorderThickness="1">
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#2E7D32"
                               Text="{Binding RestoOrMissingDisplay, Mode=OneWay}"/>
                </Border>
                <!-- Keypad: Viewbox DownOnly = non ingrandisce su schermo grande, si riduce su piccolo -->
                <Viewbox Grid.Row="5" Stretch="Uniform" StretchDirection="DownOnly" MaxWidth="520" Margin="0,6,0,0">
                    <UniformGrid Rows="4" Columns="3" Width="480" Height="360">
                        <Button Content="7" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="7"/>
                        <Button Content="8" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="8"/>
                        <Button Content="9" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="9"/>
                        <Button Content="4" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="4"/>
                        <Button Content="5" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="5"/>
                        <Button Content="6" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="6"/>
                        <Button Content="1" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="1"/>
                        <Button Content="2" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="2"/>
                        <Button Content="3" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="3"/>
                        <Button Content="0" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="0"/>
                        <Button Content="00" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource OutlineButtonStyle}" Focusable="False" Command="{Binding AppendDigitCommand}" CommandParameter="00"/>
                        <Button Content="⌫" Margin="4" Padding="12" MinHeight="64" FontSize="20" Style="{StaticResource SecondaryButtonStyle}" Focusable="False" Command="{Binding BackspaceCommand}"/>
                    </UniformGrid>
                </Viewbox>
            </Grid>
        </Border>

        <!-- Bottom: Sospendi + Annulla + Conferma pagamento -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Sospendi" MinWidth="110" Height="40" Margin="0,0,10,0"
                    Style="{StaticResource AccentButtonStyle}" Command="{Binding SuspendCommand}"/>
            <Button Content="Annulla" MinWidth="120" Height="40" Margin="0,0,10,0" Style="{StaticResource OutlineButtonStyle}" Command="{Binding CancelCommand}"/>
            <Button Content="Conferma pagamento" MinWidth="180" Height="42"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ConfirmCommand}"
                    IsEnabled="{Binding IsValid}"/>
        </StackPanel>
    </Grid>
</UserControl>
