<Window x:Class="Win7POS.Wpf.Pos.Dialogs.OverrideAuthorizationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autorizzazione supervisore"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="340"
        ResizeMode="NoResize">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="MessageText" Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,16" Foreground="#333"/>
            <TextBlock Grid.Row="1" Text="Operatore (supervisore o superiore):" Margin="0,0,0,6"/>
            <TextBox x:Name="UsernameBox" Grid.Row="2" Margin="0,0,0,8" Style="{StaticResource ModernTextBoxStyle}" MinHeight="34"/>
            <TextBlock Grid.Row="3" Text="PIN:" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PinBox" Grid.Row="4" Margin="0,0,0,16" MinHeight="34" Padding="8,6"/>
            <TextBlock x:Name="ErrorText" Grid.Row="5" Foreground="#C62828" Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed"/>
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Autorizza" MinWidth="90" Height="36" Margin="0,0,8,0" Click="OnAuthorizeClick" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True"/>
                <Button Content="Annulla" MinWidth="90" Height="36" IsCancel="True" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
