<Window x:Class="Win7POS.Wpf.Pos.Dialogs.AboutSupportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About / Support"
        Width="760"
        Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" IsReadOnly="True" Text="{Binding VersionText, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" Text="Build:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding BuildText, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Text="DB Path:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding DbPath, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" Text="Logs Directory:"/>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding LogsDirectory, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,0" Text="Backups Directory:"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding BackupsDirectory, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,0" Text="Exports Directory:"/>
        <TextBox Grid.Row="5" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding ExportsDirectory, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,0,0" Text="Printer:"/>
        <TextBox Grid.Row="6" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding PrinterName, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,6,0,0" Text="AutoPrint:"/>
        <TextBox Grid.Row="7" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding AutoPrintText, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6,0,0" Text="PIN cassa:"/>
        <TextBox Grid.Row="8" Grid.Column="1" Margin="8,6,0,0" IsReadOnly="True" Text="{Binding CashierPinStatusText, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}"/>

        <TextBlock Grid.Row="9" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="DimGray" Text="{Binding Status}" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="150" Height="36" Margin="0,0,8,0" Content="Imposta/Modifica PIN cassa" Command="{Binding SetOrChangePinCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button MinWidth="110" Height="36" Margin="0,0,8,0" Content="Rimuovi PIN" Command="{Binding RemovePinCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            <Button MinWidth="130" Height="36" Margin="0,0,8,0" Content="Apri cartella dati" Command="{Binding OpenDataFolderCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            <Button MinWidth="120" Height="36" Margin="0,0,8,0" Content="Apri cartella log" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            <Button MinWidth="90" Height="36" Margin="0,0,8,0" Content="Copia info" Command="{Binding CopyInfoCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            <Button MinWidth="90" Height="36" Content="Chiudi" IsCancel="True" Style="{StaticResource OutlineButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
