<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.AboutSupportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="About / Support"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        Width="760"
        Height="560"
        MinWidth="760"
        MaxWidth="760"
        MinHeight="560"
        MaxHeight="560">
    <Border Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="8" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*" MinWidth="240"/>
            </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" IsReadOnly="True" Text="{Binding VersionText, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Text="DB Path:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Text="{Binding DbPath, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Text="Logs Directory:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Text="{Binding LogsDirectory, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Text="Backups Directory:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Text="{Binding BackupsDirectory, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" Text="Exports Directory:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Text="{Binding ExportsDirectory, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,0,0" Text="Printer:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Text="{Binding PrinterName, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,0,0" Text="AutoPrint:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="6" Grid.Column="1" Margin="10,8,0,0" IsReadOnly="True" Text="{Binding AutoPrintText, Mode=OneWay}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32" Padding="8,6"/>

                <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="#666" Text="{Binding Status}" TextWrapping="Wrap" FontSize="11"/>

                <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Margin="0,14,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button MinWidth="110" Height="34" Margin="0,0,8,0" Content="Apri cartella dati" Command="{Binding OpenDataFolderCommand}" Style="{StaticResource OutlineButtonStyle}"/>
                    <Button MinWidth="110" Height="34" Margin="0,0,8,0" Content="Apri cartella log" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource OutlineButtonStyle}"/>
                    <Button MinWidth="88" Height="34" Margin="0,0,8,0" Content="Copia info" Command="{Binding CopyInfoCommand}" Style="{StaticResource OutlineButtonStyle}"/>
                    <Button MinWidth="88" Height="34" Content="Chiudi" IsCancel="True" Style="{StaticResource OutlineButtonStyle}"/>
                </StackPanel>
        </Grid>
    </Border>
</chrome:DialogShellWindow>
