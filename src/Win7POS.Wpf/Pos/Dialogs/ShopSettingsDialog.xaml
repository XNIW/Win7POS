<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.ShopSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{loc:Loc settings.shopTitle}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="620"
        Height="700"
        MinWidth="560"
        MinHeight="560"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Border DockPanel.Dock="Right" Style="{StaticResource FilterChipStyle}" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc settings.readOnlyBadge}" Style="{StaticResource MutedTextStyle}" FontWeight="SemiBold"/>
            </Border>
            <TextBlock Text="{loc:Loc settings.shopTitle}" Style="{StaticResource DialogTitleStyle}"/>
        </DockPanel>

        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{loc:Loc settings.shopReadOnly}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.shopName}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.shopCode}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding ShopCode}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.address}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding Address}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.city}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding City}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.companyRut}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding Rut}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.businessGiro}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding BusinessGiro}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.phone}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding Phone}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.receiptFooter}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding Footer}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc settings.lastBoleta}" Style="{StaticResource FormLabelTextStyle}" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Style="{StaticResource ReadOnlyInfoValueBorderStyle}">
                            <TextBlock Text="{Binding FiscalBoletaNumberText}" Style="{StaticResource ReadOnlyInfoValueTextStyle}"/>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource DialogPanelStyle}" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ShopStatusText, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding OfficialSourceText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LastOfficialSyncText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SyncStatusText, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CatalogSyncText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SalesSyncText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding PendingSalesText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding DeviceStatusText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Status, Mode=OneWay}" Foreground="#777" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button MinWidth="100" IsCancel="True" Style="{StaticResource DialogCancelButtonStyle}" Click="Close_Click">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
