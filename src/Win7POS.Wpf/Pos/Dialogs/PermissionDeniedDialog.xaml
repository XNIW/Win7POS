<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.PermissionDeniedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{loc:Loc common.userPermissionDenied}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Loc common.userPermissionDenied}" Style="{StaticResource DialogTitleStyle}"/>

        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="MessageText" Grid.Row="0" TextWrapping="Wrap" FontSize="14" Foreground="#444" LineHeight="22" Margin="0,0,0,28"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
                    <Button Content="{loc:Loc common.ok}" Margin="0,0,8,0" IsDefault="True" IsCancel="True" Style="{StaticResource DialogCancelButtonStyle}" Click="OnOkClick"/>
                    <Button Content="{loc:Loc operator.switch.switchOperator}" Style="{StaticResource DialogActionButtonStyle}" Click="OnSwitchClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</chrome:DialogShellWindow>
