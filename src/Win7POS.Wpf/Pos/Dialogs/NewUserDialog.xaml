<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.NewUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{loc:Loc users.newUser}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{loc:Loc users.newUser}" Style="{StaticResource DialogTitleStyle}"/>
        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*" MinWidth="180"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,10" Text="{loc:Loc users.username}" Foreground="#666"/>
            <TextBox x:Name="UsernameBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource ModernTextBoxStyle}" MinHeight="34"/>
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,10" Text="{loc:Loc users.displayName}" Foreground="#666"/>
            <TextBox x:Name="DisplayNameBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource ModernTextBoxStyle}" MinHeight="34"/>
            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,10" Text="{loc:Loc pin.pinShort}" Foreground="#666"/>
            <PasswordBox x:Name="PinBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" MinHeight="34" Padding="8,6"/>
            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,10" Text="{loc:Loc users.role}" Foreground="#666"/>
            <ComboBox x:Name="RoleCombo" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" MinHeight="34" DisplayMemberPath="Name"/>
            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
                <Button Margin="0,0,8,0" Click="OnCreateClick" Style="{StaticResource DialogActionButtonStyle}" IsDefault="True">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.create}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button IsCancel="True" Style="{StaticResource DialogCancelButtonStyle}" Click="Cancel_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.cancel}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</chrome:DialogShellWindow>
