<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.RefundDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Reso / Storno"
        ShowHeader="False"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        Width="980"
        Height="700"
        MinWidth="980"
        MaxWidth="980"
        MinHeight="700"
        MaxHeight="700"
        KeyDown="OnKeyDown">
    <Grid Margin="24" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Reso / Storno" FontSize="18" FontWeight="SemiBold" Foreground="#5E3F86" Margin="0,0,0,16"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: fascia informativa vendita -->
        <Border Grid.Row="0" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" Padding="12" CornerRadius="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Vendita:" FontWeight="SemiBold" Margin="0,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SaleCodeText, Mode=OneWay}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Data/Ora:" FontWeight="SemiBold" Margin="12,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding TimeText, Mode=OneWay}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Rimanente rimborsabile:" FontWeight="SemiBold" Margin="12,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding RemainingRefundableText, Mode=OneWay}" FontWeight="SemiBold" Foreground="#1565C0" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Totale originale:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OriginalTotalText, Mode=OneWay}" Margin="0,0,0,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Già rimborsato:" FontWeight="SemiBold" Margin="12,0,6,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding AlreadyRefundedText, Mode=OneWay}" Margin="0,0,0,0" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Selettore modalità: due card -->
        <TextBlock Grid.Row="1" Text="Tipo operazione" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Border x:Name="CardStorno" Padding="14,10" Margin="0,0,10,0" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="CardStorno_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFullVoid}" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Storno totale" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="Annulla completamente la vendita" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border x:Name="CardReso" Padding="14,10" Margin="0,0,0,0" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="CardReso_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPartialReturn}" Value="True">
                                <Setter Property="Background" Value="#FFF3E0"/>
                                <Setter Property="BorderBrush" Value="#FF9800"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Reso parziale" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="Restituisci solo alcuni articoli" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Scanner + messaggio -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Scansiona barcode:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="BarcodeScanBox" Grid.Column="1"
                         Style="{StaticResource ModernTextBoxStyle}"
                         KeyDown="BarcodeScanBox_KeyDown"
                         ToolTip="Inserisci barcode e premi Invio per aggiungere 1 alla quantità da rendere"/>
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding ScanMessage, Mode=OneWay}" Foreground="#C62828" FontSize="11" Margin="0,0,0,4"
                       Visibility="{Binding HasScanMessage, Converter={StaticResource BoolToVis}}"/>
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Lines}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="{Binding IsFullVoid}"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEE"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA">
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="SelectableDataGridRowStyle"/>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <StaticResource ResourceKey="SelectableDataGridCellStyle"/>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" IsReadOnly="True" Width="110"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="Venduti" Binding="{Binding SoldQty}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="Già resi" Binding="{Binding RefundedQty}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="Disp." Binding="{Binding RemainingQty}" IsReadOnly="True" Width="50"/>
                    <DataGridTextColumn Header="Prezzo unit." Binding="{Binding UnitPriceDisplay}" IsReadOnly="True" Width="75"/>
                    <DataGridTextColumn Header="Da rendere" Binding="{Binding QtyToRefund, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    <DataGridTextColumn Header="Totale reso" Binding="{Binding RefundLineTotalDisplay}" IsReadOnly="True" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Blocco totali + motivo -->
        <Border Grid.Row="4" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" Padding="12" CornerRadius="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Rimborso selezionato:" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" Text="{Binding RefundTotalText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Margin="16,0,6,0" VerticalAlignment="Center" Text="Motivo:"/>
                <TextBox Grid.Column="3" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" VerticalAlignment="Center" MinWidth="120"/>
            </Grid>
        </Border>

        <!-- Rimborso per metodo + messaggio + pulsanti: due righe per evitare sovrapposizioni -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Riga 1: Contanti / Carta / pulsanti rapidi / messaggio mancante -->
            <WrapPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="Contanti:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="CashRefundBox" Width="90" Margin="0,0,12,0" Text="{Binding CashRefund, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" VerticalAlignment="Center"/>
                <Button Content="Tutto contanti" Command="{Binding AllCashCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0"/>
                <TextBlock Text="Carta:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Width="90" Margin="0,0,12,0" Text="{Binding CardRefund, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" VerticalAlignment="Center"/>
                <Button Content="Tutto carta" Command="{Binding AllCardCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0"/>
                <Button Content="Dividi 50/50" Command="{Binding SplitHalfCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0" ToolTip="Metà contanti, metà carta"/>
                <Button Content="Azzera" Command="{Binding ZeroRefundCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="#C62828" Text="{Binding MissingText}" FontWeight="SemiBold" Margin="0,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
            </WrapPanel>
            <!-- Riga 2: solo Conferma e Annulla, sempre visibili e mai sovrapposti -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button MinWidth="120" Height="40" Margin="0,0,10,0" Content="Conferma" Click="OnConfirmClick" Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="{Binding IsValid}"/>
                <Button MinWidth="120" Height="40" Content="Annulla" IsCancel="True" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</chrome:DialogShellWindow>
