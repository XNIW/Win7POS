<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.RefundDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{loc:Loc refund.title}"
        ShowHeader="False"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        ResizeMode="CanResize"
        Width="980"
        Height="700"
        MinWidth="720"
        MinHeight="520"
        KeyDown="OnKeyDown">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{loc:Loc refund.title}" Style="{StaticResource DialogTitleStyle}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid Margin="0" MinWidth="700">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: fascia informativa vendita -->
        <Border Grid.Row="0" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" Padding="12" CornerRadius="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc common.sale}" FontWeight="SemiBold" Margin="0,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SaleCodeText, Mode=OneWay}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Loc common.time}" FontWeight="SemiBold" Margin="12,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding TimeText, Mode=OneWay}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="{loc:Loc refund.remaining}" FontWeight="SemiBold" Margin="12,0,6,4"/>
                <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding RemainingRefundableText, Mode=OneWay}" FontWeight="SemiBold" Foreground="#1565C0" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc refund.originalTotal}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OriginalTotalText, Mode=OneWay}" Margin="0,0,0,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{loc:Loc refund.alreadyRefunded}" FontWeight="SemiBold" Margin="12,0,6,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding AlreadyRefundedText, Mode=OneWay}" Margin="0,0,0,0" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Selettore modalità: due card -->
        <TextBlock Grid.Row="1" Text="{loc:Loc refund.operationType}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Border x:Name="CardStorno" Padding="14,10" Margin="0,0,10,0" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                    Focusable="True" MouseLeftButtonDown="CardStorno_Click" KeyDown="CardStorno_KeyDown"
                    AutomationProperties.Name="{loc:Loc refund.fullVoid}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFullVoid}" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#5E3F86"/>
                                <Setter Property="BorderThickness" Value="3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{loc:Loc refund.fullVoid}" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="{loc:Loc refund.fullVoidHelp}" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border x:Name="CardReso" Padding="14,10" Margin="0,0,0,0" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Cursor="Hand"
                    Focusable="True" MouseLeftButtonDown="CardReso_Click" KeyDown="CardReso_KeyDown"
                    AutomationProperties.Name="{loc:Loc refund.partialReturn}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPartialReturn}" Value="True">
                                <Setter Property="Background" Value="#FFF3E0"/>
                                <Setter Property="BorderBrush" Value="#FF9800"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#5E3F86"/>
                                <Setter Property="BorderThickness" Value="3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{loc:Loc refund.partialReturn}" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="{loc:Loc refund.partialReturnHelp}" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Scanner + messaggio -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc refund.scanBarcode}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="BarcodeScanBox" Grid.Column="1"
                         Style="{StaticResource ModernTextBoxStyle}"
                         KeyDown="BarcodeScanBox_KeyDown"
                         ToolTip="{loc:Loc refund.scanTooltip}"/>
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding ScanMessage, Mode=OneWay}" Foreground="#C62828" FontSize="11" Margin="0,0,0,4"
                       Visibility="{Binding HasScanMessage, Converter={StaticResource BoolToVis}}"/>
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Lines}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="{Binding IsFullVoid}"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEE"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA">
                <DataGrid.RowStyle>
                    <StaticResource ResourceKey="SelectableDataGridRowStyle"/>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <StaticResource ResourceKey="SelectableDataGridCellStyle"/>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc pos.cart.barcode}" Binding="{Binding Barcode}" IsReadOnly="True" Width="110"/>
                    <DataGridTextColumn Header="{loc:Loc refund.name}" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="{loc:Loc refund.sold}" Binding="{Binding SoldQty}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="{loc:Loc refund.alreadyReturned}" Binding="{Binding RefundedQty}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="{loc:Loc refund.available}" Binding="{Binding RemainingQty}" IsReadOnly="True" Width="50"/>
                    <DataGridTextColumn Header="{loc:Loc refund.unitPrice}" Binding="{Binding UnitPriceDisplay}" IsReadOnly="True" Width="75"/>
                    <DataGridTextColumn Header="{loc:Loc refund.toReturn}" Binding="{Binding QtyToRefund, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    <DataGridTextColumn Header="{loc:Loc refund.returnTotal}" Binding="{Binding RefundLineTotalDisplay}" IsReadOnly="True" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Blocco totali + motivo -->
        <Border Grid.Row="4" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" Padding="12" CornerRadius="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc refund.selectedRefund}" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" Text="{Binding RefundTotalText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Margin="16,0,6,0" VerticalAlignment="Center" Text="{loc:Loc refund.reason}"/>
                <TextBox Grid.Column="3" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" VerticalAlignment="Center" MinWidth="120"/>
            </Grid>
        </Border>

        <!-- Rimborso per metodo + messaggio -->
        <WrapPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="{loc:Loc common.cash}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="CashRefundBox" Width="90" Margin="0,0,12,0" Text="{Binding CashRefund, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" VerticalAlignment="Center"/>
            <Button Command="{Binding AllCashCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconCashDrawer}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc refund.allCash}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <TextBlock Text="{loc:Loc common.card}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Width="90" Margin="0,0,12,0" Text="{Binding CardRefund, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" VerticalAlignment="Center"/>
            <Button Command="{Binding AllCardCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconPay}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc refund.allCard}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SplitHalfCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0" ToolTip="{loc:Loc refund.splitTooltip}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconDuplicate}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc refund.splitHalf}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ZeroRefundCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,12,0">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc refund.zero}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <TextBlock VerticalAlignment="Center" Foreground="#C62828" Text="{Binding MissingText}" FontWeight="SemiBold" Margin="0,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
        </WrapPanel>
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button MinWidth="120" Margin="0,0,10,0" Click="OnConfirmClick" Style="{StaticResource DialogActionButtonStyle}"
                    IsEnabled="{Binding IsValid}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconRefund}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.confirm}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button MinWidth="120" IsCancel="True" Command="{Binding CancelCommand}" Style="{StaticResource DialogCancelButtonStyle}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.cancel}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
