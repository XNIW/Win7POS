<Window x:Class="Win7POS.Wpf.Pos.Dialogs.DiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sconto"
        Width="380"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundLightBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ControlTemplate x:Key="RoundedToggleTemplate" TargetType="ToggleButton">
            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="DiscountToggleStyle" TargetType="ToggleButton">
            <Setter Property="Template" Value="{StaticResource RoundedToggleTemplate}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="KeypadBtn" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" HorizontalAlignment="Right" Margin="0,0,0,8"
                   Foreground="#5C3D7A" Cursor="Hand" MouseDown="Chiudi_Click" Text="Chiudi"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <ToggleButton Content="Percentuale %" MinWidth="140" Height="36" Margin="0,0,8,0"
                         IsChecked="{Binding IsPercentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DiscountToggleStyle}"/>
            <ToggleButton Content="Importo $" MinWidth="140" Height="36"
                         IsChecked="{Binding IsAmountMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DiscountToggleStyle}"/>
        </StackPanel>

        <TextBox x:Name="ValueBox" Grid.Row="2" Height="52" FontSize="24" Margin="0,0,0,12"
                 Style="{StaticResource ModernTextBoxStyle}"
                 Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="True" HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>

        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Row="0" Grid.Column="0" Content="7" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="7"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="8"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="9"/>
            <Button Grid.Row="1" Grid.Column="0" Content="4" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="4"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="5"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="6"/>
            <Button Grid.Row="2" Grid.Column="0" Content="1" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="1"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="2"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="3"/>
            <Button Grid.Row="3" Grid.Column="0" Content="0" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="0"/>
            <Button Grid.Row="3" Grid.Column="1" Content="." Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter=","/>
            <Button Grid.Row="3" Grid.Column="2" Content="⌫" Margin="2" FontSize="18" Style="{StaticResource KeypadBtn}"
                    Command="{Binding BackspaceCommand}"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Sconto intero carrello" MinHeight="42" Margin="0,0,10,0"
                    Command="{Binding ApplyCartCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPercentMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" MinWidth="110" Height="42" Margin="0,0,10,0"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Conferma" MinWidth="110" Height="42"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
