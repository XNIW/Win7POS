<Window x:Class="Win7POS.Wpf.Pos.Dialogs.DiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sconto"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="760"
        Height="860"
        MinWidth="760"
        MinHeight="860"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundLightBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ControlTemplate x:Key="RoundedToggleTemplate" TargetType="ToggleButton">
            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="DiscountToggleStyle" TargetType="ToggleButton">
            <Setter Property="Template" Value="{StaticResource RoundedToggleTemplate}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="KeypadBtn" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="68"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <ToggleButton x:Name="PercentToggle" Content="Percentuale %" MinWidth="140" Height="36" Margin="0,0,8,0"
                         IsChecked="{Binding IsPercentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DiscountToggleStyle}"
                         Checked="Tab_Checked"/>
            <ToggleButton x:Name="ImportoToggle" Content="Importo $" MinWidth="140" Height="36"
                         IsChecked="{Binding IsAmountMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DiscountToggleStyle}"
                         Checked="Tab_Checked"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding ScopeText}" Margin="0,8,0,12"
                   FontSize="13" FontWeight="SemiBold"/>

        <!-- Anteprima prezzo: originale barrato → prezzo finale + badge sconto (altezza fissa per tab uguali) -->
        <Border Grid.Row="2" Margin="0,0,0,0" Padding="14" CornerRadius="10" Background="White" BorderBrush="#DDD" BorderThickness="1"
                Visibility="{Binding ShowPreview, Converter={StaticResource BoolToVis}}">
            <Border.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </Border.Resources>
            <StackPanel>
                <TextBlock Text="{Binding ScopeText}" FontSize="13" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="{Binding OriginalPriceDisplay}" Foreground="#777" FontSize="18" TextDecorations="Strikethrough"/>
                    <TextBlock Text="  →  " FontSize="18" Foreground="#777"/>
                    <TextBlock Text="{Binding PreviewFinalPriceDisplay}" FontSize="28" FontWeight="Bold" Foreground="#2E2E2E"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                            Visibility="{Binding HasPreviewDiscount, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding PreviewDiscountPercentDisplay}" Foreground="#8B6914" FontWeight="SemiBold"/>
                    <TextBlock Text="  "/>
                    <TextBlock Text="{Binding PreviewDiscountAmountDisplay}" Foreground="#6F6475"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,0,0,0">
            <TextBox x:Name="ValueBox" FontSize="28" Padding="16,8" Margin="0,0,0,4"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                     HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
            <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,0"
                       Text="0 = rimuovi sconto · Percentuale massima: 100"
                       Visibility="{Binding IsPercentMode, Converter={StaticResource BoolToVis}}"/>
            <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,0"
                       Text="Inserisci prezzo finale unitario desiderato"
                       Visibility="{Binding IsAmountMode, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,0,0,0">
            <UniformGrid Rows="4" Columns="3">
                <Button Content="7" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="7"/>
                <Button Content="8" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="8"/>
                <Button Content="9" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="9"/>
                <Button Content="4" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="4"/>
                <Button Content="5" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="5"/>
                <Button Content="6" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="6"/>
                <Button Content="1" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="1"/>
                <Button Content="2" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="2"/>
                <Button Content="3" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="3"/>
                <Button Content="0" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="0"/>
                <Button Content="00" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="00"/>
                <Button Content="⌫" Style="{StaticResource KeypadBtn}"
                    Command="{Binding BackspaceCommand}"/>
            </UniformGrid>
        </Grid>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" MinHeight="42" Margin="0,0,16,0" VerticalAlignment="Center">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPercentMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Sconto intero carrello" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ToggleButton Grid.Column="1" Style="{StaticResource TinyToggleSwitchStyle}"
                              IsChecked="{Binding ApplyToWholeCart, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Grid.Column="1" Text="{Binding ScopeText}" VerticalAlignment="Center"
                       FontSize="13" FontWeight="SemiBold"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" MinWidth="110" Height="42" Margin="0,0,10,0" IsCancel="True"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Conferma" MinWidth="110" Height="42" IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
