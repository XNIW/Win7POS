<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.DiscountDialog"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
       Title="Sconto"
       ShowHeader="False"
       UseModalOverlay="True"
       DialogCornerRadius="16"
       DialogBackground="#F1EDF7"
       DialogBorderBrush="#D9CEE8"
       WindowStartupLocation="CenterOwner"
       SizeToContent="Manual"
       Width="420"
       Height="528"
       MinWidth="420"
       MinHeight="528"
       ResizeMode="NoResize"
       ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.Resources>
            <ControlTemplate x:Key="RoundedToggleTemplate" TargetType="ToggleButton">
                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12,9">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#EDE5F5"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsChecked" Value="True"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                        </MultiTrigger.Conditions>
                        <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    </MultiTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
            <Style x:Key="DiscountToggleStyle" TargetType="ToggleButton">
                <Setter Property="Template" Value="{StaticResource RoundedToggleTemplate}"/>
                <Setter Property="Background" Value="#F3EDF8"/>
                <Setter Property="Foreground" Value="#5E3F86"/>
                <Setter Property="BorderBrush" Value="#D9CEE8"/>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="KeypadBtn" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Sconto"
                   Style="{StaticResource DialogTitleStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ToggleButton x:Name="PercentToggle" Content="Percentuale %" MinWidth="120" Height="32" Margin="0,0,6,0"
                         IsChecked="{Binding IsPercentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DiscountToggleStyle}"
                         Checked="Tab_Checked"/>
            <ToggleButton x:Name="ImportoToggle" Content="Importo $" MinWidth="120" Height="32"
                         IsChecked="{Binding IsAmountMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DiscountToggleStyle}"
                         Checked="Tab_Checked"/>
        </StackPanel>

        <Border Grid.Row="2" Margin="0,0,0,10" Padding="12" CornerRadius="8" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1"
                Visibility="{Binding ShowPreview, Converter={StaticResource BoolToVis}}">
            <Border.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </Border.Resources>
            <StackPanel>
                <TextBlock Text="{Binding ScopeText}" FontSize="13" FontWeight="SemiBold" Foreground="#5E3F86"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{Binding OriginalPriceDisplay}" Foreground="#999" FontSize="14" TextDecorations="Strikethrough"/>
                    <TextBlock Text="  →  " FontSize="14" Foreground="#AAA"/>
                    <TextBlock Text="{Binding PreviewFinalPriceDisplay}" FontSize="20" FontWeight="Bold" Foreground="#2E2E2E"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                            Visibility="{Binding HasPreviewDiscount, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding PreviewDiscountPercentDisplay}" Foreground="#8B6914" FontWeight="SemiBold"/>
                    <TextBlock Text="  "/>
                    <TextBlock Text="{Binding PreviewDiscountAmountDisplay}" Foreground="#8873A4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBox x:Name="ValueBox" MinHeight="50" FontSize="22" Padding="12,6" Margin="0,0,0,4"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                     HorizontalContentAlignment="Right" VerticalContentAlignment="Center"/>
            <TextBlock FontSize="11" Foreground="#8873A4"
                       Text="0 = rimuovi sconto · Percentuale massima: 100"
                       Visibility="{Binding IsPercentMode, Converter={StaticResource BoolToVis}}"/>
            <TextBlock FontSize="11" Foreground="#8873A4"
                       Text="Inserisci prezzo finale unitario desiderato"
                       Visibility="{Binding IsAmountMode, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Border Grid.Row="4" Height="1" Background="#E4DBEF" Margin="0,0,0,10"/>

        <Grid Grid.Row="5">
            <UniformGrid Rows="4" Columns="3">
                <Button Content="7" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="7"/>
                <Button Content="8" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="8"/>
                <Button Content="9" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="9"/>
                <Button Content="4" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="4"/>
                <Button Content="5" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="5"/>
                <Button Content="6" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="6"/>
                <Button Content="1" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="1"/>
                <Button Content="2" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="2"/>
                <Button Content="3" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="3"/>
                <Button Content="0" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="0"/>
                <Button Content="00" Style="{StaticResource KeypadBtn}"
                    Command="{Binding DigitCommand}" CommandParameter="00"/>
                <Button Content="⌫" Style="{StaticResource KeypadBtn}"
                    Command="{Binding BackspaceCommand}"/>
            </UniformGrid>
        </Grid>

        <Grid Grid.Row="6" Margin="{StaticResource DialogFooterMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding ScopeText}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#5E3F86"
                           TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPercentMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Intero carrello"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="#5E3F86"/>
                    <ToggleButton Style="{StaticResource TinyToggleSwitchStyle}"
                                  IsChecked="{Binding ApplyToWholeCart, Mode=TwoWay}"
                                  VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Annulla" Margin="0,0,8,0" IsCancel="True"
                        Style="{StaticResource DialogCancelButtonStyle}"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Conferma" IsDefault="True"
                        Style="{StaticResource DialogActionButtonStyle}"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</chrome:DialogShellWindow>
