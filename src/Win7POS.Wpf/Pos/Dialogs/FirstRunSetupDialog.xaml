<Window x:Class="Win7POS.Wpf.Pos.Dialogs.FirstRunSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurazione iniziale"
        Width="520"
        MinWidth="520"
        Height="440"
        MinHeight="440"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Padding="0" Background="{StaticResource BackgroundLightBrush}">
        <Grid Margin="24,20,24,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Configurazione iniziale" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Grid.Row="1" Text="Crea il primo amministratore del sistema" FontSize="13" Foreground="#555" Margin="0,4,0,0"/>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Nome operatore:"/>
                <TextBox x:Name="DisplayNameBox" Grid.Row="0" Grid.Column="1" MinHeight="30" Style="{StaticResource ModernTextBoxStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Username:"/>
                <TextBox x:Name="UsernameBox" Grid.Row="2" Grid.Column="1" MinHeight="30" Style="{StaticResource ModernTextBoxStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="PIN (4-6 cifre):"/>
                <PasswordBox x:Name="PinBox" Grid.Row="4" Grid.Column="1" MinHeight="30" Padding="8,6"/>

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Conferma PIN:"/>
                <PasswordBox x:Name="ConfirmPinBox" Grid.Row="6" Grid.Column="1" MinHeight="30" Padding="8,6"/>
            </Grid>

            <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="#C62828" TextWrapping="Wrap" Visibility="Collapsed" VerticalAlignment="Top" Margin="0,4,0,0"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Conferma" Width="100" Height="34" Margin="0,0,8,0" Click="OnCreateAdminClick" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True"/>
                <Button Content="Annulla" Width="100" Height="34" IsCancel="True" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
