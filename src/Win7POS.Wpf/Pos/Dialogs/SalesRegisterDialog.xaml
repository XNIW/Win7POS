<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.SalesRegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Registro vendite"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        Width="1000"
        Height="750"
        ShowInTaskbar="False"
        MinWidth="900"
        MinHeight="640"
        KeyDown="OnWindowKeyDown">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Registro vendite" FontSize="18" FontWeight="SemiBold" Foreground="#5E3F86" Margin="0,0,0,10"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" MinWidth="340"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.95*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- SINISTRA: filtri su più righe + lista -->
            <Border Grid.Column="0" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Riga 1: filtri rapidi tempo -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="Oggi" IsChecked="{Binding FilterOggi, Mode=TwoWay}" Margin="0,0,14,0" GroupName="Filter" VerticalAlignment="Center"/>
                        <RadioButton Content="Ieri" IsChecked="{Binding FilterIeri, Mode=TwoWay}" Margin="0,0,14,0" GroupName="Filter" VerticalAlignment="Center"/>
                        <RadioButton Content="7 giorni" IsChecked="{Binding Filter7G, Mode=TwoWay}" Margin="0,0,14,0" GroupName="Filter" VerticalAlignment="Center"/>
                        <RadioButton Content="Mese" IsChecked="{Binding FilterMese, Mode=TwoWay}" Margin="0,0,14,0" GroupName="Filter" VerticalAlignment="Center"/>
                        <RadioButton Content="Periodo" IsChecked="{Binding FilterPeriodo, Mode=TwoWay}" Margin="0,0,0,0" GroupName="Filter" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Riga 2: Dal / Al solo quando Periodo -->
                    <Grid Grid.Row="1" Margin="0,0,0,10"
                          Visibility="{Binding IsRangeFilter, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Dal:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding RangeFrom}" Margin="0,0,14,0"/>
                        <TextBlock Grid.Column="2" Text="Al:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Grid.Column="3" SelectedDate="{Binding RangeTo}"/>
                    </Grid>

                    <!-- Riga 3: Operatore (se disponibile) -->
                    <Grid Grid.Row="2" Margin="0,0,0,8" Visibility="{Binding HasOperatorFilter, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" MinWidth="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Operatore:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                        <ComboBox Grid.Column="1" MinHeight="32" ItemsSource="{Binding OperatorFilterList}" SelectedItem="{Binding SelectedOperator, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Riga 4: Codice + TextBox + Ricarica -->
                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" MinWidth="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Codice:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555"/>
                        <TextBox x:Name="CodeSearchBox" Grid.Column="1" MinHeight="32"
                                 Text="{Binding CodeSearch, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 KeyDown="CodeSearchBox_KeyDown"
                                 ToolTip="Cerca per codice (Invio ricarica)"/>
                        <Button Grid.Column="3" Content="Ricarica" MinWidth="90" Height="34" Command="{Binding LoadCommand}" Style="{StaticResource OutlineButtonStyle}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Lista scontrini -->
                    <ListBox Grid.Row="4" ItemsSource="{Binding SalesList}" SelectedItem="{Binding SelectedSale, Mode=TwoWay}"
                             BorderThickness="0" Background="Transparent" Padding="0,0,4,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                                <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                                <Setter Property="Foreground" Value="#222"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EEE8F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="10,8" Margin="0,0,0,4">
                                    <Grid TextElement.Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="85"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{Binding BadgeBrush}" CornerRadius="4" Padding="5,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindText, Mode=OneWay}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="{Binding SaleCode}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding VoidedText, Mode=OneWay}" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="DarkRed" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TimeText, Mode=OneWay}" Margin="0,2,0,0" FontSize="11" Foreground="#666"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalDisplay, Mode=OneWay}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Footer statistiche -->
                    <Border Grid.Row="5" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" Padding="10,8" CornerRadius="8">
                        <TextBlock Text="{Binding Status, Mode=OneWay}" Foreground="#555" TextTrimming="CharacterEllipsis" FontSize="11"/>
                    </Border>
                </Grid>
            </Border>

            <!-- DESTRA: dettaglio vendita (senza anteprima scontrino; Stampa stampa l'intero scontrino) -->
            <Border Grid.Column="2" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header dettaglio + lucchetto vista -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Dettaglio vendita" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding DetailSummary, Mode=OneWay}" TextWrapping="Wrap" FontSize="12" Foreground="#444" LineHeight="18"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Visibility="{Binding HasLockFeature, Converter={StaticResource BoolToVis}}">
                            <Button Content="{Binding LockGlyph, Mode=OneWay}" Command="{Binding ToggleHiddenModeCommand}" ToolTip="Sblocca/Blocca vista completa (solo Admin)"
                                    Style="{StaticResource OutlineButtonStyle}" Width="36" Height="36" Padding="0" FontSize="15"/>
                        </StackPanel>
                    </Grid>

                    <!-- Righe articoli: area principale con scroll -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,14">
                        <ItemsControl ItemsSource="{Binding DetailLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='x{0}'}" Margin="12,0" VerticalAlignment="Center" Foreground="#555"/>
                                        <TextBlock Grid.Column="2" Text="{Binding UnitPriceDisplay, Mode=OneWay}" Margin="8,0" MinWidth="72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding LineTotalDisplay, Mode=OneWay}" FontWeight="SemiBold" MinWidth="72" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Footer: Chiudi + Stampa + Reso/Storno -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Chiudi" MinWidth="90" Height="40" HorizontalAlignment="Left"
                                IsCancel="True" Style="{StaticResource OutlineButtonStyle}"
                                Click="Close_Click"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Stampa" MinWidth="110" Height="40" Command="{Binding PrintCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,10,0"/>
                            <Button Content="Reso / Storno" MinWidth="140" Height="40" Command="{Binding RefundCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</chrome:DialogShellWindow>
