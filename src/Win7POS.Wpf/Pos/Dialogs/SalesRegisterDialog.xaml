<Window x:Class="Win7POS.Wpf.Pos.Dialogs.SalesRegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro vendite" Width="920" Height="580"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinWidth="780" MinHeight="480">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="340" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        <!-- Colonna sinistra: filtri + lista vendite -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Filtri" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <WrapPanel>
                    <RadioButton Content="Oggi" IsChecked="{Binding FilterOggi, Mode=TwoWay}" Margin="0,0,12,0" GroupName="Filter"/>
                    <RadioButton Content="Ieri" IsChecked="{Binding FilterIeri, Mode=TwoWay}" Margin="0,0,12,0" GroupName="Filter"/>
                    <RadioButton Content="7 giorni" IsChecked="{Binding Filter7G, Mode=TwoWay}" Margin="0,0,12,0" GroupName="Filter"/>
                    <RadioButton Content="Mese" IsChecked="{Binding FilterMese, Mode=TwoWay}" Margin="0,0,12,0" GroupName="Filter"/>
                    <RadioButton Content="Periodo" IsChecked="{Binding FilterPeriodo, Mode=TwoWay}" Margin="0,0,12,0" GroupName="Filter"/>
                    <Button Content="Ricarica" MinWidth="88" Command="{Binding LoadCommand}" Margin="8,0,0,0" Style="{StaticResource OutlineButtonStyle}"/>
                </WrapPanel>
                <Grid Margin="0,6,0,0"
                      Visibility="{Binding IsRangeFilter, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Da:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding RangeFrom}"/>
                    <TextBlock Grid.Column="2" Text="A:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <DatePicker Grid.Column="3" SelectedDate="{Binding RangeTo}"/>
                </Grid>
            </StackPanel>
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Codice:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="CodeSearchBox" Grid.Column="1" Text="{Binding CodeSearch, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBoxStyle}"
                         KeyDown="CodeSearchBox_KeyDown"
                         ToolTip="Cerca per codice vendita (Invio per cercare, lascia vuoto per usare il periodo)"/>
            </Grid>
            <ListBox Grid.Row="3" ItemsSource="{Binding SalesList}" SelectedItem="{Binding SelectedSale, Mode=TwoWay}"
                     BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource CardBgBrush}" Padding="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Margin="0,0,0,8">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                        <Setter Property="Foreground" Value="#222"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEE8F0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="10,8" Margin="0,0,0,2">
                            <Grid TextElement.Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <WrapPanel>
                                        <Border Background="{Binding BadgeBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,6,4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding KindText, Mode=OneWay}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="{Binding SaleCode}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VoidedText, Mode=OneWay}" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="DarkRed"/>
                                    </WrapPanel>
                                    <TextBlock FontSize="11" Opacity="0.75" Text="{Binding TimeText, Mode=OneWay}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding TotalDisplay, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <TextBlock Text="{Binding Status, Mode=OneWay}" VerticalAlignment="Center" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>

        <!-- Colonna destra: dettagli + azioni -->
        <Border Grid.Column="2" Style="{StaticResource DialogPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Dettaglio vendita" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Text="{Binding DetailSummary, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,10"
                           FontSize="12" Foreground="#333"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <ItemsControl ItemsSource="{Binding DetailLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='x{0}'}" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding UnitPriceDisplay, Mode=OneWay}" Margin="8,0" MinWidth="70" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding LineTotalDisplay, Mode=OneWay}" FontWeight="SemiBold" MinWidth="70" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="3" Background="{StaticResource BackgroundLightBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10" CornerRadius="6">
                    <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding DetailReceiptPreview, Mode=OneWay}" FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Stampa" MinWidth="90" Height="36" Margin="0,0,8,0" Command="{Binding PrintCommand}" Style="{StaticResource OutlineButtonStyle}"/>
                    <Button Content="Reso / Storno" MinWidth="120" Height="36" Command="{Binding RefundCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
