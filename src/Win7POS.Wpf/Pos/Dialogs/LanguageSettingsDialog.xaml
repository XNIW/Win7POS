<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.LanguageSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{loc:Loc settings.language}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="430"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Background="#F1EDF7" FocusManager.FocusedElement="{Binding ElementName=LanguageComboBox}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Loc settings.language}" Style="{StaticResource DialogTitleStyle}"/>

        <Border Grid.Row="1"
                Background="#FCFBFE"
                BorderBrush="#E4DBEF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18"
                Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="{loc:Loc settings.languageDialogHelp}"
                           Style="{StaticResource MutedTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="LanguageComboBox"
                          MinWidth="280"
                          MinHeight="36"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          Style="{StaticResource ModernComboBoxStyle}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource DialogFooterMargin}">
            <Button x:Name="ApplyButton"
                    Style="{StaticResource DialogActionButtonStyle}"
                    IsDefault="True"
                    Click="OnApplyClick"
                    Margin="0,0,8,0">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconCheck}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.apply}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource DialogCancelButtonStyle}"
                    IsCancel="True"
                    Click="OnCloseClick">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
