<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.RoleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Ruolo"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        ResizeMode="NoResize">
    <Border Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*" MinWidth="180"/>
            </Grid.ColumnDefinitions>
            <Grid x:Name="CodeRow" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*" MinWidth="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CodeLabel" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0" Text="Codice ruolo:"/>
                <StackPanel Grid.Column="1">
                    <TextBox x:Name="CodeBox" Margin="0,0,0,4" Style="{StaticResource ModernTextBoxStyle}" MinHeight="34"/>
                    <TextBlock Text="Interno, univoco, minuscolo, senza spazi. Es: dipendente" Foreground="#6B5B73" FontSize="11" Margin="0,0,0,10"/>
                </StackPanel>
            </Grid>
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0" Text="Nome visibile:"/>
            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBox x:Name="NameBox" Margin="0,0,0,4" Style="{StaticResource ModernTextBoxStyle}" MinHeight="34"/>
                <TextBlock Text="Testo mostrato all'operatore. Es: Dipendente" Foreground="#6B5B73" FontSize="11" Margin="0,0,0,10"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="OK" MinWidth="90" Height="36" Margin="0,0,8,0" Click="OnOkClick" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True"/>
                <Button Content="Annulla" MinWidth="90" Height="36" IsCancel="True" Style="{StaticResource OutlineButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</chrome:DialogShellWindow>
