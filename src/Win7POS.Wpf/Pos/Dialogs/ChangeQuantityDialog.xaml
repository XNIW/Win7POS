<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.ChangeQuantityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Modifica quantità"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        MinHeight="320"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.Resources>
            <Style x:Key="KeypadBtn" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="Height" Value="72"/>
                <Setter Property="Margin" Value="6"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Modifica quantità" FontSize="18" FontWeight="SemiBold" Foreground="#5E3F86" Margin="0,0,0,10"/>
        <TextBlock x:Name="ProductNameText" Grid.Row="1" FontWeight="SemiBold" FontSize="13" Foreground="#5E3F86" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <TextBlock Grid.Row="2" Text="Quantità" Foreground="#666" Margin="0,0,0,6"/>
        <TextBox x:Name="QtyBox" Grid.Row="3" MinHeight="52" FontSize="24" Margin="0,0,0,16"
                 Style="{StaticResource ModernTextBoxStyle}"
                 KeyDown="QtyBox_KeyDown"/>
        <Border Grid.Row="4" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,16">
        <UniformGrid Rows="4" Columns="3">
            <Button Content="7" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="8" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="9" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="4" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="5" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="6" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="1" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="2" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="3" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="0" Style="{StaticResource KeypadBtn}" Click="Digit_Click"/>
            <Button Content="00" Style="{StaticResource KeypadBtn}" Click="DoubleZero_Click"/>
            <Button Content="⌫" Style="{StaticResource KeypadBtn}" Click="Backspace_Click"/>
        </UniformGrid>
        </Border>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Annulla" MinWidth="90" Height="42" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click" Style="{StaticResource OutlineButtonStyle}"/>
            <Button Content="OK" MinWidth="90" Height="42" IsDefault="True" Click="Ok_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
