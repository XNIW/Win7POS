<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.SettingsHubDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{loc:Loc shell.settings}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="760"
        Height="620"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Loc shell.settings}" Style="{StaticResource DialogTitleStyle}"/>
            <TextBlock Text="{loc:Loc settings.hubIntro}" Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel>
                <TextBlock Text="{loc:Loc settings.groupStore}" Style="{StaticResource SettingsSectionHeaderTextStyle}"/>
                <UniformGrid x:Name="StoreSettingsGrid" Columns="2">
                    <Button x:Name="ShopDataButton" Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnShopDataClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconShop}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc shell.officialShopData}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardShopHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>

                    <Button x:Name="PrinterSettingsButton" Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnPrinterSettingsClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconPrinter}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc shell.printerSettings}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardPrinterHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>

                    <Button x:Name="OnlineAccessButton" Visibility="Collapsed" Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnOnlineAccessClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconSync}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc access.login.retryOnline}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardOnlineAccessHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>
                </UniformGrid>

                <TextBlock Text="{loc:Loc settings.groupWorkstation}" Style="{StaticResource SettingsSectionHeaderTextStyle}"/>
                <UniformGrid x:Name="WorkstationSettingsGrid" Columns="2">
                    <Button x:Name="CustomerDisplayButton" Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnCustomerDisplayClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconMonitor}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc customerDisplay.settings.title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc customerDisplay.settings.cardHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnLanguageClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconLanguage}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc settings.language}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardLanguageHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>
                </UniformGrid>

                <TextBlock Text="{loc:Loc settings.groupAdministration}" Style="{StaticResource SettingsSectionHeaderTextStyle}"/>
                <UniformGrid x:Name="AdministrationSettingsGrid" Columns="2">
                    <Button Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnDatabaseMaintenanceClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconDatabase}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc operations.dbMaintenance}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardDatabaseHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>

                    <Button x:Name="UsersRolesButton" Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnUsersRolesClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconUsers}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc shell.usersRoles}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardUsersHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnSyncCenterClick" AutomationProperties.Name="{loc:Loc sync.center.open}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconSync}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc sync.center.title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardSyncCenterHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource CompactSettingsCardButtonStyle}" Click="OnAboutClick">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="22"/></Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconHelp}" Style="{StaticResource ButtonIconPathStyle}" Width="22" Height="22"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc shell.aboutSupport}" FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc settings.cardAboutHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="2" Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}" Width="16" Height="16"/>
                        </Grid>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button Style="{StaticResource DialogCancelButtonStyle}"
                    IsCancel="True"
                    Click="OnCloseClick">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
