<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.SettingsHubDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{loc:Loc shell.settings}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="760"
        Height="560"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Loc shell.settings}" Style="{StaticResource DialogTitleStyle}"/>
            <TextBlock Text="{loc:Loc settings.hubIntro}" Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2" Rows="3">
            <Button Style="{StaticResource SettingsCardButtonStyle}" Click="OnShopDataClick">
                <StackPanel>
                    <Path Data="{StaticResource IconShop}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.officialShopData}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardShopHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SettingsCardButtonStyle}" Click="OnPrinterSettingsClick">
                <StackPanel>
                    <Path Data="{StaticResource IconPrinter}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.printerSettings}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardPrinterHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SettingsCardButtonStyle}" Click="OnDatabaseMaintenanceClick">
                <StackPanel>
                    <Path Data="{StaticResource IconDatabase}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc operations.dbMaintenance}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardDatabaseHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SettingsCardButtonStyle}" Click="OnUsersRolesClick">
                <StackPanel>
                    <Path Data="{StaticResource IconUsers}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.usersRoles}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardUsersHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Border Margin="6"
                    Padding="14"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <Path Data="{StaticResource IconLanguage}"
                          Style="{StaticResource SettingsCardIconPathStyle}"
                          Stroke="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.language}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardLanguageHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,8"/>
                    <ComboBox x:Name="LanguageComboBox"
                              MinHeight="34"
                              Style="{StaticResource ModernComboBoxStyle}"
                              SelectionChanged="OnLanguageSelectionChanged"/>
                </StackPanel>
            </Border>

            <Button Style="{StaticResource SettingsCardButtonStyle}" Click="OnAboutClick">
                <StackPanel>
                    <Path Data="{StaticResource IconHelp}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.aboutSupport}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardAboutHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button Style="{StaticResource DialogCancelButtonStyle}"
                    IsCancel="True"
                    Click="OnCloseClick">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
