<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.SettingsHubDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        Title="{loc:Loc shell.settings}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="760"
        Height="620"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="0" Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Loc shell.settings}" Style="{StaticResource DialogTitleStyle}"/>
            <TextBlock Text="{loc:Loc settings.hubIntro}" Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <Button x:Name="ShopDataButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsCardButtonStyle}" Click="OnShopDataClick">
                <StackPanel>
                    <Path Data="{StaticResource IconShop}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.officialShopData}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardShopHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button x:Name="PrinterSettingsButton" Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsCardButtonStyle}" Click="OnPrinterSettingsClick">
                <StackPanel>
                    <Path Data="{StaticResource IconPrinter}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.printerSettings}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardPrinterHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsCardButtonStyle}" Click="OnDatabaseMaintenanceClick">
                <StackPanel>
                    <Path Data="{StaticResource IconDatabase}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc operations.dbMaintenance}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardDatabaseHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button x:Name="UsersRolesButton" Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsCardButtonStyle}" Click="OnUsersRolesClick">
                <StackPanel>
                    <Path Data="{StaticResource IconUsers}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.usersRoles}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardUsersHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsCardButtonStyle}" Click="OnAboutClick">
                <StackPanel>
                    <Path Data="{StaticResource IconHelp}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc shell.aboutSupport}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardAboutHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsCardButtonStyle}" Click="OnLanguageClick">
                <StackPanel>
                    <Path Data="{StaticResource IconLanguage}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc settings.language}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardLanguageHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource SettingsCardButtonStyle}"
                    Click="OnSyncCenterClick"
                    AutomationProperties.Name="{loc:Loc sync.center.open}">
                <StackPanel>
                    <Path Data="{StaticResource IconSync}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc sync.center.title}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc settings.cardSyncCenterHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

            <Button x:Name="CustomerDisplayButton"
                    Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource SettingsCardButtonStyle}"
                    Click="OnCustomerDisplayClick">
                <StackPanel>
                    <Path Data="{StaticResource IconMonitor}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc customerDisplay.settings.title}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc customerDisplay.settings.cardHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Button>

                <Button x:Name="OnlineAccessButton" Grid.Row="0" Grid.Column="0" Visibility="Collapsed" Style="{StaticResource SettingsCardButtonStyle}" Click="OnOnlineAccessClick">
                    <StackPanel>
                        <Path Data="{StaticResource IconSync}" Style="{StaticResource SettingsCardIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc access.login.retryOnline}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc settings.cardOnlineAccessHelp}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button Style="{StaticResource DialogCancelButtonStyle}"
                    IsCancel="True"
                    Click="OnCloseClick">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
