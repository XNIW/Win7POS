<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.UserManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{loc:Loc users.title}"
        ShowHeader="False"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="720"
        MinHeight="480"
        ResizeMode="CanResize">
    <Grid Margin="0" Background="#F1EDF7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Header: titolo + operatore corrente -->
            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                <TextBlock Text="{loc:Loc users.title}" Style="{StaticResource DialogTitleStyle}" Margin="0"/>
                <TextBlock Text="{Binding CurrentOperatorDisplay, Mode=OneWay}" FontSize="12" Foreground="#8873A4" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Colonna sinistra: Utenti e Ruoli in blocchi separati -->
            <StackPanel Grid.Row="1" Grid.Column="0">
                <!-- Blocco Utenti -->
                <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc users.users}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UserFilterTextBox" Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="10,0,32,0"/>
                            <TextBlock Grid.Column="0" Text="{loc:Loc users.searchPlaceholder}" Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="#8A7C93" FontSize="12" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UserFilterTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Grid.Column="1" Width="28" Height="28" Margin="2,0,0,0" Command="{Binding ClearFilterCommand}"
                                    ToolTip="{loc:Loc users.clearFilter}" Style="{StaticResource OutlineButtonStyle}" Padding="0" FontSize="12" VerticalAlignment="Center"
                                    Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVis}}">
                                <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}" Width="12" Height="12"/>
                            </Button>
                        </Grid>
                        <ListBox ItemsSource="{Binding FilteredUsers}" SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                 MinHeight="140" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Username}"/>
                                        <TextBlock FontSize="11" Foreground="#6B5B73" Margin="0,2,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} • {1}">
                                                    <Binding Path="DisplayName"/>
                                                    <Binding Path="RoleName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{loc:Loc users.currentUserMarker}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0">
                                            <TextBlock.Visibility>
                                                <MultiBinding Converter="{StaticResource EqToVis}">
                                                    <Binding Path="Username"/>
                                                    <Binding Path="DataContext.CurrentOperatorUsername" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                        <TextBlock Text="{loc:Loc users.inactive}" FontSize="10" Foreground="#8A7C93" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Text="{Binding EmptyUsersMessage}" Foreground="#8A7C93" FontSize="12" Margin="4,6,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsersListEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding NewUserCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Padding="12,6" Margin="0,8,0,0">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc users.newUser}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Blocco Ruoli -->
                <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc users.rolesEditPermissions}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                 MinHeight="90" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Loc users.systemSuffix}" Foreground="Gray" FontStyle="Italic" FontSize="11" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="1">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Text="{Binding SelectedRoleSystemInfo}" FontSize="11" Foreground="#6B5B73" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,8,0,0" Visibility="{Binding CanManageRoles, Converter={StaticResource BoolToVis}}">
                            <Button Command="{Binding NewRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                                    <TextBlock Text="{loc:Loc users.newRole}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DuplicateRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{loc:Loc users.duplicateRoleTooltip}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <Path Data="{StaticResource IconDuplicate}" Style="{StaticResource ButtonIconPathStyle}"/>
                                    <TextBlock Text="{loc:Loc users.duplicate}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RenameRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{Binding RenameRoleToolTip}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <Path Data="{StaticResource IconEdit}" Style="{StaticResource ButtonIconPathStyle}"/>
                                    <TextBlock Text="{loc:Loc users.rename}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{Binding DeleteRoleToolTip}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <Path Data="{StaticResource IconDelete}" Style="{StaticResource ButtonIconPathStyle}"/>
                                    <TextBlock Text="{loc:Loc common.delete}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Colonna destra: Dettaglio utente (Auto) + Permessi ruolo (* con ScrollViewer) -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="16,0,0,0" IsEnabled="{Binding HasSelection}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Card Dettaglio utente -->
                <Border Grid.Row="0" Visibility="{Binding IsUserSelected, Converter={StaticResource BoolToVis}}" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc users.selectedUser}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{loc:Loc users.username}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SelectedUsername}" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{loc:Loc firstRun.operatorName}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{loc:Loc users.role}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ItemsSource="{Binding Roles}" SelectedValue="{Binding SelectedRoleId}" SelectedValuePath="Id" DisplayMemberPath="Name" MinHeight="34"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{loc:Loc users.accessStatus}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsActive}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding AccountStatusText}" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="{loc:Loc operator.login.pin}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
                                <PasswordBox x:Name="NewPinBox" MinHeight="34" Padding="8,6" PasswordChanged="NewPinBox_PasswordChanged"/>
                                <TextBlock Text="{loc:Loc users.leaveEmptyNoChange}" FontSize="11" Foreground="#8A7C93" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Command="{Binding SaveUserCommand}" MinWidth="90" Height="36" Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                                        <TextBlock Text="{loc:Loc users.saveUser}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CancelUserChangesCommand}" MinWidth="90" Height="36" Margin="0,0,8,0" Style="{StaticResource OutlineButtonStyle}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                                        <TextBlock Text="{loc:Loc users.cancelChanges}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ResetPinCommand}" MinWidth="90" Height="36" Style="{StaticResource OutlineButtonStyle}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <Path Data="{StaticResource IconLock}" Style="{StaticResource ButtonIconPathStyle}"/>
                                        <TextBlock Text="{loc:Loc users.resetPin}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card Permessi ruolo: titolo + area scrollabile + pulsante -->
                <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" MinHeight="200">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="{loc:Loc users.selectedRolePermissions}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding PermessiRoleSystemMessage}" FontSize="11" Foreground="#6B5B73" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="{Binding PermessiRoleSystemMessageVisibility}"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="PermissionItemsControl">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,4"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Content="{Binding Label}" Margin="0,2" IsEnabled="{Binding IsEditable}" ToolTip="{Binding ToolTip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Button Grid.Row="2" Visibility="{Binding CanSaveSelectedRolePermissions, Converter={StaticResource BoolToVis}}" Command="{Binding SaveRolePermissionsCommand}" Style="{StaticResource OutlineButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" ToolTip="{Binding SaveRolePermissionsToolTip}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc users.saveRolePermissions}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="{StaticResource DialogFooterMargin}" Foreground="Gray" FontSize="11" Text="{Binding Status, Mode=OneWay}"/>
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
                <Button IsCancel="True" Click="OnCloseClick" Style="{StaticResource DialogCancelButtonStyle}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.close}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
</chrome:DialogShellWindow>
