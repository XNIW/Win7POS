<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.PosStartOfDaySyncDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{loc:Loc startOfDay.title}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="560"
        MinHeight="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Loc startOfDay.title}" Style="{StaticResource DialogTitleStyle}"/>

        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
            <StackPanel>
                <TextBlock Text="{loc:Loc startOfDay.subtitle}" Foreground="#665D73" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <UniformGrid Columns="1" Margin="0,0,0,12">
                    <TextBlock x:Name="StepDatabaseText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepSessionText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepOutboxText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepSalesText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepCatalogText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepCompleteText" Margin="0,2,0,2" Foreground="#514A5E"/>
                </UniformGrid>

                <ProgressBar x:Name="StartOfDayProgressBar" Height="12" IsIndeterminate="True" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="StatusText" Margin="0,10,0,0" Foreground="#514A5E" TextWrapping="Wrap"/>
                <TextBlock x:Name="CountsText" Margin="0,5,0,0" Foreground="#7A6F88" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button x:Name="ContinueButton" Content="{loc:Loc startOfDay.continue}" MinWidth="110" Height="42" Margin="0,0,10,0" Click="Continue_Click" Style="{StaticResource DialogActionButtonStyle}" IsDefault="True" IsEnabled="False"/>
            <Button x:Name="WaitButton" Content="{loc:Loc startOfDay.wait}" MinWidth="150" Height="42" Margin="0,0,10,0" Click="Wait_Click" Style="{StaticResource DialogCancelButtonStyle}" Visibility="Collapsed"/>
            <Button x:Name="RetryButton" Content="{loc:Loc startOfDay.retry}" MinWidth="100" Height="42" Margin="0,0,10,0" Click="Retry_Click" Style="{StaticResource DialogCancelButtonStyle}" Visibility="Collapsed"/>
            <Button Content="{loc:Loc startOfDay.exit}" MinWidth="100" Height="42" IsCancel="True" Style="{StaticResource DialogCancelButtonStyle}" Click="Exit_Click"/>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
