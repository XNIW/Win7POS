<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.PosStartOfDaySyncDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="{loc:Loc startOfDay.title}"
        ShowHeader="False"
        UseModalOverlay="True"
        DialogCornerRadius="16"
        DialogBackground="#F1EDF7"
        DialogBorderBrush="#D9CEE8"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="640"
        MinHeight="420"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Background="#F1EDF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Loc startOfDay.title}" Style="{StaticResource DialogTitleStyle}"/>

        <Border Grid.Row="1" Background="#FCFBFE" BorderBrush="#E4DBEF" BorderThickness="1" CornerRadius="10" Padding="18">
            <StackPanel>
                <TextBlock Text="{loc:Loc startOfDay.subtitle}" Foreground="#665D73" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <Border x:Name="AccessVerifiedPanel"
                        Background="#EAF5EC"
                        BorderBrush="#B9D8C0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,9"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="{StaticResource IconCheck}"
                              Fill="#28733A"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="AccessVerifiedText"
                                       Foreground="#205D30"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       AutomationProperties.LiveSetting="Polite"/>
                            <TextBlock Text="{loc:Loc startOfDay.accessVerifiedHelp}"
                                       Foreground="#3E6648"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Columns="1" Margin="0,0,0,12">
                    <TextBlock x:Name="StepDatabaseText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepSessionText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepOutboxText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepSalesText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepCatalogText" Margin="0,2,0,2" Foreground="#514A5E"/>
                    <TextBlock x:Name="StepCompleteText" Margin="0,2,0,2" Foreground="#514A5E"/>
                </UniformGrid>

                <ProgressBar x:Name="StartOfDayProgressBar" Height="12" IsIndeterminate="True" Minimum="0" Maximum="100" AutomationProperties.Name="{loc:Loc startOfDay.checking}"/>
                <TextBlock x:Name="StatusText" Margin="0,10,0,0" Foreground="#514A5E" TextWrapping="Wrap" AutomationProperties.Name="{loc:Loc startOfDay.checking}" AutomationProperties.LiveSetting="Assertive"/>
                <TextBlock x:Name="CountsText" Margin="0,5,0,0" Foreground="#7A6F88" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite"/>
                <TextBlock x:Name="ActionHelpText"
                           Margin="0,10,0,0"
                           Foreground="#8A4D00"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource DialogFooterMargin}">
            <Button x:Name="ContinueButton" MinWidth="110" Height="42" Margin="0,0,10,0" Click="Continue_Click" Style="{StaticResource DialogActionButtonStyle}" IsDefault="True" IsEnabled="False" AutomationProperties.Name="{loc:Loc startOfDay.continue}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc startOfDay.continue}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="WaitButton" MinWidth="150" Height="42" Margin="0,0,10,0" Click="Wait_Click" Style="{StaticResource DialogCancelButtonStyle}" Visibility="Collapsed" AutomationProperties.Name="{loc:Loc startOfDay.wait}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconCalendar}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc startOfDay.wait}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="SyncDetailsButton" MinWidth="130" Height="42" Margin="0,0,10,0" Click="SyncDetails_Click" Style="{StaticResource DialogCancelButtonStyle}" Visibility="Collapsed" AutomationProperties.Name="{loc:Loc startOfDay.syncDetails}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconHelp}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc startOfDay.syncDetails}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button x:Name="RetryButton" MinWidth="120" Height="42" Margin="0,0,10,0" Click="Retry_Click" Style="{StaticResource DialogCancelButtonStyle}" Visibility="Collapsed" AutomationProperties.Name="{loc:Loc startOfDay.checkAgain}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconSync}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc startOfDay.checkAgain}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <Button MinWidth="100" Height="42" IsCancel="True" Style="{StaticResource DialogCancelButtonStyle}" Click="Exit_Click" AutomationProperties.Name="{loc:Loc startOfDay.exit}">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                    <TextBlock Text="{loc:Loc startOfDay.exit}" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</chrome:DialogShellWindow>
