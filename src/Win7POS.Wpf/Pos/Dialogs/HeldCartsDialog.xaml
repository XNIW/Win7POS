<Window x:Class="Win7POS.Wpf.Pos.Dialogs.HeldCartsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scontrini sospesi"
        Width="480"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scontrini sospesi" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedHold}"
                 Margin="0,0,0,8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding HoldId}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="Gray" VerticalAlignment="Center" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Recupera" MinWidth="100" Height="36" Margin="0,0,8,0"
                    Command="{Binding RecoverCommand}" Background="#5C3D7A" Foreground="White" BorderThickness="0"/>
            <Button Content="Elimina" MinWidth="80" Height="36" Margin="0,0,8,0"
                    Command="{Binding DeleteCommand}" Background="#7B5A8E" Foreground="White" BorderThickness="0"/>
            <Button Content="Chiudi" MinWidth="80" Height="36"
                    Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>
