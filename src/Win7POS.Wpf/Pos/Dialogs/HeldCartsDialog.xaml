<chrome:DialogShellWindow x:Class="Win7POS.Wpf.Pos.Dialogs.HeldCartsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chrome="clr-namespace:Win7POS.Wpf.Chrome"
        Title="Scontrini sospesi"
        ShowHeader="False"
        DialogCornerRadius="16"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        Width="660"
        Height="400"
        MinWidth="620"
        MinHeight="360"
        MaxWidth="760"
        MaxHeight="520"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*" MinWidth="280"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="0.95*" MinWidth="180"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="Scontrini sospesi"
                   FontWeight="SemiBold" FontSize="20"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="4,2,0,14"/>

        <!-- Lista sospesi -->
        <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="6" Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedHold}"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Margin" Value="0,0,0,2"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding HoldId}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="#666" FontSize="11" VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Anteprima scontrino: colonna più stretta, contenuto compatto -->
        <Border Grid.Row="1" Grid.Column="2" Background="White" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Anteprima" FontWeight="SemiBold" FontSize="11" Foreground="#666" Margin="0,0,0,6"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding SelectedLines}" BorderThickness="0" Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                            <Setter Property="Padding" Value="0,4"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding DetailLine}" FontSize="10" Foreground="#888" Margin="0,1,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Footer: stato + pulsanti -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Status, Mode=OneWay}" VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="0,0,12,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Recupera" MinWidth="100" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}" Command="{Binding RecoverCommand}"/>
                <Button Content="Elimina" MinWidth="84" Height="36" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DeleteCommand}"/>
                <Button Content="Chiudi" MinWidth="84" Height="36"
                        Style="{StaticResource OutlineButtonStyle}" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</chrome:DialogShellWindow>
