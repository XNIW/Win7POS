<Window x:Class="Win7POS.Wpf.Pos.Dialogs.HeldCartsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scontrini sospesi"
        Width="720"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundLightBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Scontrini sospesi" FontWeight="SemiBold" FontSize="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,14"/>

        <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,14" Padding="4">
            <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedHold}"
                     BorderThickness="0" Background="Transparent"
                     >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding HoldId}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="Gray" VerticalAlignment="Center" Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding TotalDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,14" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Anteprima scontrino" FontWeight="SemiBold" FontSize="12" Foreground="Gray" Margin="0,0,0,6"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding SelectedLines}" BorderThickness="0" Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,6">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding DetailLine}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Status, Mode=OneWay}" VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,0,12,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Recupera" MinWidth="110" Height="40" Margin="0,0,10,0"
                        Style="{StaticResource PrimaryButtonStyle}" Command="{Binding RecoverCommand}"/>
                <Button Content="Elimina" MinWidth="90" Height="40" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DeleteCommand}"/>
                <Button Content="Chiudi" MinWidth="90" Height="40"
                        Style="{StaticResource OutlineButtonStyle}" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
