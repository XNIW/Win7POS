<Window x:Class="Win7POS.Wpf.Pos.CustomerDisplay.MonitorIdentifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Identify monitor"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Topmost="True"
        Background="#D9181520">
    <Border BorderBrush="White" BorderThickness="6" Margin="24" CornerRadius="18" IsHitTestVisible="False">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="NumberText" Foreground="White" FontSize="168" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="MonitorText" Foreground="White" FontSize="28" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
