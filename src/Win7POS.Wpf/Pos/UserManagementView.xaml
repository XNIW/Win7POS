<UserControl x:Class="Win7POS.Wpf.Pos.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{loc:Loc users.title}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="{Binding CurrentOperatorDisplay}" Margin="0,4,0,0" Foreground="#6B5B73" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Command="{Binding ReloadCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0" Padding="12,6">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Data="{StaticResource IconSync}" Style="{StaticResource ButtonIconPathStyle}"/>
                        <TextBlock Text="{loc:Loc common.reload}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 4 colonne: proporzioni bilanciate per Win7 1024x768 (utenti / utente sel. / ruolo sel. / permessi) -->
        <Grid Grid.Row="1" MinWidth="800">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.28*"/>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="1.90*"/>
            </Grid.ColumnDefinitions>

            <!-- 1) Utenti -->
            <Border Grid.Column="0" Margin="0,0,6,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{loc:Loc users.users}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserFilterTextBox" Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="10,0,32,0"/>
                        <TextBlock Grid.Column="0" Text="{loc:Loc users.searchPlaceholder}" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#8A7C93" FontSize="12" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=UserFilterTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="1" Width="28" Height="28" Margin="2,0,0,0" Command="{Binding ClearFilterCommand}"
                                ToolTip="{loc:Loc users.clearFilter}" Style="{StaticResource OutlineButtonStyle}" Padding="0" FontSize="12" VerticalAlignment="Center"
                                Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVis}}">
                            <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}" Width="12" Height="12"/>
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding FilteredUsers}" SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                 BorderThickness="0" Background="Transparent" Padding="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource DisplayNameOrUsername}">
                                                    <Binding Path="DisplayName"/>
                                                    <Binding Path="Username"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#6B5B73" Margin="0,2,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="@{0} • {1}">
                                                    <Binding Path="Username"/>
                                                    <Binding Path="RoleName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{loc:Loc users.currentUserMarker}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0">
                                            <TextBlock.Visibility>
                                                <MultiBinding Converter="{StaticResource EqToVis}">
                                                    <Binding Path="Username"/>
                                                    <Binding Path="DataContext.CurrentOperatorUsername" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                        <TextBlock Text="{loc:Loc users.inactive}" FontSize="10" Foreground="#8A7C93" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <StackPanel Grid.Row="3">
                        <TextBlock Text="{Binding EmptyUsersMessage}" Foreground="#8A7C93" FontSize="12" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsersListEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding NewUserCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Padding="12,6" Margin="0,8,0,0">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc users.newUser}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2) Dettaglio utente: due stati distinti (form / placeholder) senza sovrapposizioni -->
            <Border Grid.Column="1" Margin="0,0,6,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" MinWidth="200">
                <Grid>
                    <!-- Form: visibile solo quando c'è selezione -->
                    <Grid Visibility="{Binding HasSelectedUser, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc users.selectedUser}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" MinWidth="90"/>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,6">
                                    <TextBlock Text="{loc:Loc users.loginUsername}"/>
                                    <TextBlock Text="{loc:Loc users.loginUsernameHint}" FontSize="10" Foreground="#8A7C93" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedUsername}" Foreground="#555" FontSize="12"/>
                                    <TextBlock Text="{loc:Loc users.readOnly}" FontSize="10" Foreground="#8A7C93" Margin="0,1,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,6">
                                    <TextBlock Text="{loc:Loc users.visibleName}"/>
                                    <TextBlock Text="{loc:Loc users.displayNameHint}" FontSize="10" Foreground="#8A7C93" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="32"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,6" Text="{loc:Loc users.role}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" ItemsSource="{Binding Roles}" SelectedValue="{Binding SelectedRoleId}" SelectedValuePath="Id" DisplayMemberPath="Name" MinHeight="32"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,6" Text="{loc:Loc users.accessStatus}"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsActive}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding AccountStatusText}" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,6" Text="{loc:Loc operator.login.pin}"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                                    <PasswordBox x:Name="NewPinBox" MinHeight="32" Padding="6,4" PasswordChanged="NewPinBox_PasswordChanged"/>
                                    <TextBlock Text="{loc:Loc users.leaveEmptyNoChange}" FontSize="11" Foreground="#8A7C93" Margin="0,2,0,0"/>
                                </StackPanel>
                                <!-- Pulsanti stacked verticalmente per evitare taglio su 1024x768 -->
                                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,4,0,0">
                                    <Button Command="{Binding SaveUserCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="8,6" Margin="0,0,0,6" HorizontalAlignment="Left" MinWidth="120">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                                            <TextBlock Text="{loc:Loc users.saveUser}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding CancelUserChangesCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,0,6" HorizontalAlignment="Left" MinWidth="120">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Data="{StaticResource IconClear}" Style="{StaticResource ButtonIconPathStyle}"/>
                                            <TextBlock Text="{loc:Loc users.cancelChanges}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ResetPinCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" HorizontalAlignment="Left" MinWidth="120">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Data="{StaticResource IconLock}" Style="{StaticResource ButtonIconPathStyle}"/>
                                            <TextBlock Text="{loc:Loc users.resetPin}" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Placeholder: centrato, solo quando non c'è selezione -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasSelectedUser, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc users.selectedUser}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8" TextAlignment="Center"/>
                            <TextBlock Text="{loc:Loc users.noUserSelected}" FontSize="22" Foreground="#7A6F86" Margin="0,0,0,6" TextAlignment="Center"/>
                            <TextBlock Text="{loc:Loc users.selectUserHelp}"
                                       FontSize="12" Foreground="#8A7C93" TextWrapping="Wrap" MaxWidth="220" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 3) Ruolo selezionato -->
            <Border Grid.Column="2" Margin="0,0,6,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{loc:Loc users.selectedRole}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                 BorderThickness="0" Background="Transparent" Padding="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}">
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Loc users.systemSuffix}" Foreground="Gray" FontStyle="Italic" FontSize="11" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="1">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SelectedRoleDescription}" FontSize="12" Foreground="#6B5B73" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedRoleOperativeDescription}" FontSize="11" Foreground="#8A7C93" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        <Border Background="#E8E0F0" CornerRadius="4" Padding="6,4" Margin="0,6,0,0" HorizontalAlignment="Left" Visibility="{Binding IsSelectedRoleSystem, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{loc:Loc users.systemRole}" FontSize="11" FontWeight="SemiBold" Foreground="#4B2E67"/>
                        </Border>
                    </StackPanel>
                    <WrapPanel Grid.Row="3" Visibility="{Binding CanManageRoles, Converter={StaticResource BoolToVis}}">
                        <Button Command="{Binding NewRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc users.newRole}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DuplicateRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{loc:Loc users.duplicateRoleTooltip}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconDuplicate}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc users.duplicateRole}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RenameRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{Binding RenameRoleToolTip}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconEdit}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc users.rename}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{Binding DeleteRoleToolTip}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <Path Data="{StaticResource IconDelete}" Style="{StaticResource ButtonIconPathStyle}"/>
                                <TextBlock Text="{loc:Loc common.delete}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- 4) Permessi del ruolo selezionato: area stretch, bottone vicino alla lista -->
            <Border Grid.Column="3" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" MinHeight="200">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="{loc:Loc users.selectedRolePermissions}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding PermessiRoleSystemMessage}" FontSize="11" Foreground="#6B5B73" Margin="0,4,0,0" TextWrapping="Wrap" Visibility="{Binding PermessiRoleSystemMessageVisibility}"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" HorizontalAlignment="Stretch">
                        <ItemsControl x:Name="PermissionItemsControl" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,4"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Content="{Binding Label}" Margin="0,2" IsEnabled="{Binding IsEditable}" ToolTip="{Binding ToolTip}" HorizontalAlignment="Left"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="2" Visibility="{Binding CanSaveSelectedRolePermissions, Converter={StaticResource BoolToVis}}" Command="{Binding SaveRolePermissionsCommand}" Style="{StaticResource OutlineButtonStyle}" HorizontalAlignment="Left" Margin="0,8,0,0" ToolTip="{Binding SaveRolePermissionsToolTip}">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Data="{StaticResource IconGo}" Style="{StaticResource ButtonIconPathStyle}"/>
                            <TextBlock Text="{loc:Loc users.saveRolePermissions}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer: solo messaggio di stato (nessun bottone Annulla) -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,6,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#6B5B73" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
