<UserControl x:Class="Win7POS.Wpf.Pos.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:Win7POS.Wpf.Converters"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EqualityToVisibilityConverter x:Key="EqToVis"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Utenti e ruoli" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="{Binding CurrentOperatorDisplay}" Margin="0,4,0,0" Foreground="#6B5B73" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Ricarica" Command="{Binding ReloadCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0" Padding="12,6"/>
            </StackPanel>
        </Grid>

        <!-- 4 colonne: larghezze conservative per Win7 / schermi piccoli -->
        <Grid Grid.Row="1" MinWidth="800">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200"/>
                <ColumnDefinition Width="300" MinWidth="260"/>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 1) Utenti -->
            <Border Grid.Column="0" Margin="0,0,8,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Utenti" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserFilterTextBox" Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="10,0,32,0"/>
                        <TextBlock Grid.Column="0" Text="Cerca per username o nome" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#8A7C93" FontSize="12" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=UserFilterTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="1" Content="✕" Width="28" Height="28" Margin="2,0,0,0" Command="{Binding ClearFilterCommand}"
                                ToolTip="Svuota filtro" Style="{StaticResource OutlineButtonStyle}" Padding="0" FontSize="12" VerticalAlignment="Center"
                                Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding FilteredUsers}" SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                 BorderThickness="0" Background="Transparent" Padding="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Username}"/>
                                        <TextBlock FontSize="11" Foreground="#6B5B73" Margin="0,2,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} • {1}">
                                                    <Binding Path="DisplayName"/>
                                                    <Binding Path="RoleName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="• utente attuale" FontSize="10" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0">
                                            <TextBlock.Visibility>
                                                <MultiBinding Converter="{StaticResource EqToVis}">
                                                    <Binding Path="Username"/>
                                                    <Binding Path="DataContext.CurrentOperatorUsername" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                        <TextBlock Text="Disattivo" FontSize="10" Foreground="#8A7C93" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <StackPanel Grid.Row="3">
                        <TextBlock Text="{Binding EmptyUsersMessage}" Foreground="#8A7C93" FontSize="12" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsersListEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="Nuovo utente" Command="{Binding NewUserCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Padding="12,6" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2) Dettaglio utente: card sempre visibile, placeholder quando nessun utente -->
            <Border Grid.Column="1" Margin="0,0,8,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUserSelected}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <TextBlock Text="Seleziona un utente dalla lista." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8A7C93" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUserSelected}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel>
                        <TextBlock Text="Utente selezionato" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Username:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding SelectedUsername}" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Nome operatore:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Ruolo:"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" ItemsSource="{Binding Roles}" SelectedValue="{Binding SelectedRoleId}" SelectedValuePath="Id" DisplayMemberPath="Name" MinHeight="34"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="Stato accesso:"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsActive}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding AccountStatusText}" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8" Text="PIN:"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
                                <PasswordBox x:Name="NewPinBox" MinHeight="34" Padding="8,6" PasswordChanged="NewPinBox_PasswordChanged"/>
                                <TextBlock Text="Lascia vuoto per non modificare." FontSize="11" Foreground="#8A7C93" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Salva utente" Command="{Binding SaveUserCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="10,6" Margin="0,0,8,0"/>
                                <Button Content="Annulla modifiche" Command="{Binding CancelUserChangesCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="10,6" Margin="0,0,8,0"/>
                                <Button Content="Reimposta PIN" Command="{Binding ResetPinCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="10,6"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3) Ruolo selezionato -->
            <Border Grid.Column="2" Margin="0,0,8,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Ruolo selezionato" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                 BorderThickness="0" Background="Transparent" Padding="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" (sistema)" Foreground="Gray" FontStyle="Italic" FontSize="11" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="1">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SelectedRoleDescription}" FontSize="12" Foreground="#6B5B73" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedRoleOperativeDescription}" FontSize="11" Foreground="#8A7C93" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        <Border Background="#E8E0F0" CornerRadius="4" Padding="6,4" Margin="0,6,0,0" HorizontalAlignment="Left" Visibility="{Binding IsSelectedRoleSystem, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Ruolo di sistema" FontSize="11" FontWeight="SemiBold" Foreground="#4B2E67"/>
                        </Border>
                    </StackPanel>
                    <WrapPanel Grid.Row="3">
                        <Button Content="Nuovo ruolo" Command="{Binding NewRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8"/>
                        <Button Content="Duplica ruolo" Command="{Binding DuplicateRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="Duplica il ruolo selezionato con gli stessi permessi."/>
                        <Button Content="Rinomina" Command="{Binding RenameRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{Binding RenameRoleToolTip}"/>
                        <Button Content="Elimina" Command="{Binding DeleteRoleCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="8,6" Margin="0,0,8,8" ToolTip="{Binding DeleteRoleToolTip}"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- 4) Permessi del ruolo selezionato -->
            <Border Grid.Column="3" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" MinHeight="200">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Permessi del ruolo selezionato" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding PermessiRoleSystemMessage}" FontSize="11" Foreground="#6B5B73" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="{Binding PermessiRoleSystemMessageVisibility}"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="PermissionItemsControl">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,4"/>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Content="{Binding Label}" Margin="0,2" IsEnabled="{Binding IsEditable}" ToolTip="{Binding ToolTip}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="2" Visibility="{Binding CanEditSelectedRole, Converter={StaticResource BoolToVis}}" Content="Salva permessi ruolo" Command="{Binding SaveRolePermissionsCommand}" Style="{StaticResource OutlineButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" ToolTip="{Binding SaveRolePermissionsToolTip}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#6B5B73" FontSize="11"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Annulla" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="12,6"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
