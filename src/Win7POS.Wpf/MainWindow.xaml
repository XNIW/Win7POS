<Window x:Class="Win7POS.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pos="clr-namespace:Win7POS.Wpf.Pos"
        xmlns:prod="clr-namespace:Win7POS.Wpf.Products"
        xmlns:core="clr-namespace:Win7POS.Core;assembly=Win7POS.Core"
        Title="Win7POS" MinWidth="1024" MinHeight="600" WindowState="Maximized">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header con hamburger (nascosto in modalità Pagamento) -->
        <Border x:Name="TopHeaderBar" Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="HamburgerButton" Grid.Column="0" Width="40" Height="40" Margin="0,0,16,0"
                        Style="{StaticResource HamburgerButtonStyle}"
                        Click="OnHamburgerClick"
                        ToolTip="Menu">
                    <Button.Content>
                        <Path Stroke="White" StrokeThickness="2" Data="M 6,8 L 26,8 M 6,14 L 26,14 M 6,20 L 26,20"/>
                    </Button.Content>
                </Button>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Win7POS"/>
            </Grid>
        </Border>

        <!-- Contenuto principale: TabControl (tab headers nascosti) -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Padding="0" BorderThickness="0" SelectedIndex="0" SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0" IsItemsHost="True" Visibility="Collapsed"/>
                        <ContentPresenter Grid.Row="1" x:Name="ContentSite" ContentSource="SelectedContent" Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="POS">
                <pos:PosView x:Name="PosViewControl"/>
            </TabItem>
            <TabItem x:Name="ProductsTab" Header="Prodotti">
                <prod:ProductsView/>
            </TabItem>
            <TabItem x:Name="PaymentTab" Header="Pagamento">
                <pos:PaymentView x:Name="PaymentViewControl"/>
            </TabItem>
        </TabControl>

        <!-- Overlay menu laterale -->
        <Grid x:Name="SideMenuOverlay" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Background="#80000000" MouseLeftButtonDown="OnOverlayClick">
            <Border x:Name="SideMenuPanel" Width="280" HorizontalAlignment="Left" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" CornerRadius="0,0,8,0" MouseLeftButtonDown="OnPanelClick">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,24,16,20">
                        <TextBlock Text="Menu" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="Navigazione" Foreground="#6B5B73" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="POS" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuPosClick"/>
                        <Button Content="Prodotti" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuProdottiClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="Gestione" Foreground="#6B5B73" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="Registro vendite" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuSalesRegisterClick"/>
                        <Button Content="Incasso giornaliero" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuDailyReportClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="Impostazioni" Foreground="#6B5B73" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="Impostazioni negozio" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuShopSettingsClick"/>
                        <Button Content="Impostazioni stampante" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuPrinterClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="Supporto" Foreground="#6B5B73" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="About / Support" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,6" Click="OnMenuAboutClick"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Barra stato inferiore (nascosta in modalità Pagamento) -->
        <Border x:Name="BottomStatusBar" Grid.Row="2" Background="{StaticResource BackgroundLightBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="DB: " VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Static core:AppPaths.DbPath}" VerticalAlignment="Center" Foreground="#555"/>
                    <Border Width="1" Margin="12,0" Background="{StaticResource BorderBrush}" VerticalAlignment="Stretch"/>
                    <CheckBox x:Name="CashierModeCheckBox"
                              Content="Modalita cassa"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"
                              Checked="OnCashierModeChecked"
                              Unchecked="OnCashierModeUnchecked"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
