<Window x:Class="Win7POS.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Win7POS.Wpf.Localization"
        xmlns:pos="clr-namespace:Win7POS.Wpf.Pos"
        xmlns:prod="clr-namespace:Win7POS.Wpf.Products"
        Title="Win7POS" MinWidth="1024" MinHeight="600" WindowState="Maximized">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header con hamburger (nascosto in modalità Pagamento) -->
        <Border x:Name="TopHeaderBar" Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="HamburgerButton" Grid.Column="0" Width="40" Height="40" Margin="0,0,16,0"
                        Style="{StaticResource HamburgerButtonStyle}"
                        Click="OnHamburgerClick"
                        ToolTip="Menu">
                    <Button.Content>
                        <Path Stroke="White" StrokeThickness="2" Data="M 6,8 L 26,8 M 6,14 L 26,14 M 6,20 L 26,20"/>
                    </Button.Content>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Win7POS"/>
                    <Border x:Name="SyncStatusPill" Margin="0,4,16,0" Padding="8,3" CornerRadius="7" Background="#26FFFFFF" BorderBrush="#66FFFFFF" BorderThickness="1" HorizontalAlignment="Left">
                        <TextBlock x:Name="SyncStatusText"
                                   Foreground="White"
                                   FontSize="11"
                                   Text="{loc:Loc shell.syncUnavailable}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="540"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#33FFFFFF" CornerRadius="8" Padding="12,6" Margin="0,0,10,0" BorderBrush="White" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="0,0,6,0" Text="{loc:Loc shell.operator}"/>
                            <TextBlock x:Name="OperatorDisplayText" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="—"/>
                            <TextBlock x:Name="OperatorRoleText" Foreground="#E8FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" Text=""/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="ShellNetworkStatusBadge" Background="#E8F2ED" CornerRadius="8" Padding="10,6" Margin="0,0,10,0" BorderBrush="#BFD9C9" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="18" Height="16" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Path x:Name="ShellNetworkWifiArcLarge" Stroke="#2E7D32" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 2,7 C 6,3 12,3 16,7"/>
                                <Path x:Name="ShellNetworkWifiArcSmall" Stroke="#2E7D32" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 5,10 C 7.5,8 10.5,8 13,10"/>
                                <Ellipse x:Name="ShellNetworkWifiDot" Width="4" Height="4" Fill="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                <Grid x:Name="ShellNetworkOfflineX" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Collapsed">
                                    <Line X1="1" Y1="1" X2="7" Y2="7" Stroke="#C62828" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="7" Y1="1" X2="1" Y2="7" Stroke="#C62828" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Grid>
                            </Grid>
                            <TextBlock x:Name="ShellNetworkStatusText" Foreground="#2E7D32" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Text="{loc:Loc access.login.networkOfflineShort}"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="ChangeOperatorButton" Style="{StaticResource HeaderActionButtonStyle}" Click="OnChangeOperatorClick" ToolTip="{loc:Loc shell.changeLockTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Loc shell.changeLock}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenuto principale: TabControl (tab headers nascosti) -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Padding="0" BorderThickness="0" SelectedIndex="0" SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0" IsItemsHost="True" Visibility="Collapsed"/>
                        <ContentPresenter Grid.Row="1" x:Name="ContentSite" ContentSource="SelectedContent" Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="POS">
                <Grid x:Name="PosTabHost"/>
            </TabItem>
            <TabItem x:Name="ProductsTab" Header="{loc:Loc shell.products}">
                <prod:ProductsView x:Name="ProductsViewControl"/>
            </TabItem>
            <TabItem x:Name="DailyReportTab" Header="{loc:Loc shell.dailyClose}">
                <pos:DailyReportView x:Name="DailyReportViewControl"/>
            </TabItem>
            <TabItem x:Name="PaymentTab" Header="{loc:Loc common.pay}">
                <pos:PaymentView x:Name="PaymentViewControl"/>
            </TabItem>
            <TabItem x:Name="UsersRolesTab" Header="{loc:Loc shell.usersRoles}">
                <pos:UserManagementView x:Name="UserManagementViewControl"/>
            </TabItem>
        </TabControl>

        <!-- Overlay menu laterale -->
        <Grid x:Name="SideMenuOverlay" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Background="#80000000" MouseLeftButtonDown="OnOverlayClick">
            <Border x:Name="SideMenuPanel" Width="280" HorizontalAlignment="Left" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="0,0,1,0" CornerRadius="0,0,8,0" MouseLeftButtonDown="OnPanelClick">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,24,16,20">
                        <TextBlock Text="{loc:Loc shell.menu}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="{loc:Loc shell.navigation}" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="POS" Tag="Pos" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuPosClick"/>
                        <Button x:Name="OpenCashDrawerMenuButton" Content="{loc:Loc shell.openCashDrawer}" Tag="OpenCash" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuOpenCashDrawerClick" ToolTip="{loc:Loc shell.openCashDrawerTooltip}"/>
                        <Button Content="{loc:Loc shell.products}" Tag="Prodotti" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuProdottiClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource SidebarBorderBrush}" Height="1"/>
                        <TextBlock Text="{loc:Loc shell.management}" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="{loc:Loc shell.salesRegister}" Tag="SalesRegister" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuSalesRegisterClick"/>
                        <Button Content="{loc:Loc shell.dailyClose}" Tag="DailyReport" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuDailyReportClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource SidebarBorderBrush}" Height="1"/>
                        <TextBlock Text="{loc:Loc shell.settings}" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{loc:Loc settings.language}" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="LanguageComboBox"
                                  MinHeight="34"
                                  Margin="0,0,0,10"
                                  SelectionChanged="OnLanguageSelectionChanged"/>
                        <Button Content="{loc:Loc shell.officialShopData}" Tag="ShopSettings" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuShopSettingsClick"/>
                        <Button Content="{loc:Loc shell.printerSettings}" Tag="Printer" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuPrinterClick"/>
                        <Button Content="{loc:Loc operations.dbMaintenance}" Tag="DbMaintenance" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuDbClick"/>
                        <Button Content="{loc:Loc shell.usersRoles}" Tag="UsersRoles" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuUsersClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource SidebarBorderBrush}" Height="1"/>
                        <TextBlock Text="{loc:Loc shell.support}" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="{loc:Loc shell.aboutSupport}" Tag="About" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuAboutClick"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
