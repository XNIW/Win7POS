<Window x:Class="Win7POS.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pos="clr-namespace:Win7POS.Wpf.Pos"
        xmlns:prod="clr-namespace:Win7POS.Wpf.Products"
        Title="Win7POS" MinWidth="1024" MinHeight="600" WindowState="Maximized">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header con hamburger (nascosto in modalità Pagamento) -->
        <Border x:Name="TopHeaderBar" Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="HamburgerButton" Grid.Column="0" Width="40" Height="40" Margin="0,0,16,0"
                        Style="{StaticResource HamburgerButtonStyle}"
                        Click="OnHamburgerClick"
                        ToolTip="Menu">
                    <Button.Content>
                        <Path Stroke="White" StrokeThickness="2" Data="M 6,8 L 26,8 M 6,14 L 26,14 M 6,20 L 26,20"/>
                    </Button.Content>
                </Button>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Win7POS"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#33FFFFFF" CornerRadius="8" Padding="12,6" Margin="0,0,10,0" BorderBrush="White" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="0,0,6,0" Text="Operatore:"/>
                            <TextBlock x:Name="OperatorDisplayText" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="—"/>
                            <TextBlock x:Name="OperatorRoleText" Foreground="#E8FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" Text=""/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="ChangeOperatorButton" Content="Cambia operatore" Style="{StaticResource OutlineButtonStyle}" Foreground="White" BorderBrush="White" Click="OnChangeOperatorClick" Padding="12,6" MinWidth="120" ToolTip="Cambia operatore o blocca sessione"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenuto principale: TabControl (tab headers nascosti) -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Padding="0" BorderThickness="0" SelectedIndex="0" SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0" IsItemsHost="True" Visibility="Collapsed"/>
                        <ContentPresenter Grid.Row="1" x:Name="ContentSite" ContentSource="SelectedContent" Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="POS">
                <pos:PosView x:Name="PosViewControl"/>
            </TabItem>
            <TabItem x:Name="ProductsTab" Header="Prodotti">
                <prod:ProductsView/>
            </TabItem>
            <TabItem x:Name="DailyReportTab" Header="Chiusura cassa">
                <pos:DailyReportView x:Name="DailyReportViewControl"/>
            </TabItem>
            <TabItem x:Name="PaymentTab" Header="Pagamento">
                <pos:PaymentView x:Name="PaymentViewControl"/>
            </TabItem>
            <TabItem x:Name="UsersRolesTab" Header="Utenti e ruoli">
                <pos:UserManagementView x:Name="UserManagementViewControl"/>
            </TabItem>
        </TabControl>

        <!-- Overlay menu laterale -->
        <Grid x:Name="SideMenuOverlay" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Background="#80000000" MouseLeftButtonDown="OnOverlayClick">
            <Border x:Name="SideMenuPanel" Width="280" HorizontalAlignment="Left" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="0,0,1,0" CornerRadius="0,0,8,0" MouseLeftButtonDown="OnPanelClick">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,24,16,20">
                        <TextBlock Text="Menu" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="Navigazione" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="POS" Tag="Pos" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuPosClick"/>
                        <Button Content="Prodotti" Tag="Prodotti" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuProdottiClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource SidebarBorderBrush}" Height="1"/>
                        <TextBlock Text="Gestione" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="Registro vendite" Tag="SalesRegister" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuSalesRegisterClick"/>
                        <Button Content="Chiusura cassa" Tag="DailyReport" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuDailyReportClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource SidebarBorderBrush}" Height="1"/>
                        <TextBlock Text="Impostazioni" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="Impostazioni negozio" Tag="ShopSettings" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuShopSettingsClick"/>
                        <Button Content="Impostazioni stampante" Tag="Printer" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuPrinterClick"/>
                        <Button Content="Utenti e ruoli" Tag="UsersRoles" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuUsersClick"/>

                        <Separator Margin="0,16,0,16" Background="{StaticResource SidebarBorderBrush}" Height="1"/>
                        <TextBlock Text="Supporto" Foreground="#4B2E67" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button Content="About / Support" Tag="About" Style="{StaticResource SidebarNavButtonStyle}" Click="OnMenuAboutClick"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
